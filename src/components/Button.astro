---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'nav-signup' | 'nav-login' | 'nav-ai';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: any;
}

const { 
  variant = 'primary', 
  size = 'lg', 
  class: className = '', 
  id,
  type = 'button',
  ...rest
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-medium transition-all duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed outline-none focus-visible:ring-2 focus-visible:ring-link focus-visible:ring-offset-2";

const variants = {
  primary: "bg-primary text-on-primary hover:bg-ink/90",
  secondary: "bg-canvas text-ink border border-hairline hover:bg-canvas-soft",
  ghost: "bg-transparent text-body hover:bg-canvas-soft-2",
  'nav-signup': "bg-primary text-on-primary rounded-sm text-sm font-medium h-[28px] px-3",
  'nav-login': "bg-canvas text-ink rounded-sm text-sm font-medium h-[28px] px-3 hover:bg-canvas-soft",
  'nav-ai': "bg-canvas text-ink border border-hairline rounded-sm text-sm font-medium h-[28px] px-3 hover:bg-canvas-soft"
};

const sizes = {
  sm: "h-8 px-3 text-sm rounded-pill",
  md: "h-10 px-5 text-sm rounded-pill",
  lg: "h-12 px-8 text-base rounded-pill"
};

// Override sizes for nav variants
const isNavVariant = variant.startsWith('nav-');
const finalClasses = [
  baseStyles, 
  variants[variant], 
  !isNavVariant ? sizes[size] : "",
  className
].filter(Boolean).join(' ');
---

<button type={type} id={id} class={finalClasses} {...rest}>
  <slot />
</button>
