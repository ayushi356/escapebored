---
import Button from '../Button.astro';
---

<div class="flex flex-col items-center justify-center p-6 w-full max-w-lg mx-auto relative" data-tool="typingsprint">
  <!-- Header with crown and trophy -->
  <div class="flex justify-between items-center w-full mb-4 z-10">
    <div class="flex items-center gap-1.5">
      <span class="text-xs font-mono text-mute uppercase tracking-widest">Mindful Typing Sprint</span>
      <span id="daily-challenge-badge" class="hidden text-[9px] font-semibold text-link bg-link/10 border border-link/25 px-1.5 py-0.5 rounded">Daily Challenge</span>
    </div>
    <div class="flex items-center gap-3">
      <div id="typing-pb-display" class="flex items-center gap-1 text-[11px] font-mono text-link font-semibold" title="Personal Best WPM">
        👑 <span id="pb-wpm-val">0</span> WPM
      </div>
      <button id="typing-trophy-btn" class="p-1 rounded hover:bg-canvas-soft border border-transparent hover:border-hairline text-mute hover:text-ink transition-all cursor-pointer text-xs" title="Achievements">
        🏆
      </button>
    </div>
  </div>

  <!-- Achievements Popover Modal -->
  <div id="typing-achievements-modal" class="hidden absolute inset-0 bg-black/85 backdrop-blur-md rounded-xl p-6 z-25 flex flex-col transition-all duration-300">
    <div class="flex justify-between items-center border-b border-hairline pb-3 mb-4">
      <h5 class="text-xs font-semibold text-white tracking-widest uppercase font-mono flex items-center gap-1.5">🏆 Achievements</h5>
      <button id="achievements-close-btn" class="text-xs text-mute hover:text-ink cursor-pointer">Close</button>
    </div>
    <div class="flex-1 overflow-y-auto flex flex-col gap-3 pr-1 text-left" id="achievements-list">
      <!-- Achievements will be injected here -->
    </div>
  </div>
  
  <div id="typing-game" class="w-full">
    <!-- Quote Display Area -->
    <div 
      id="quote-container" 
      class="text-left bg-canvas-soft border border-hairline rounded-lg p-6 mb-6 font-mono text-lg md:text-xl leading-relaxed select-none relative focus-within:ring-2 focus-within:ring-link focus-within:ring-offset-2 outline-none cursor-pointer"
      tabindex="0"
    >
      <div id="quote-text" class="text-mute-strong">
        <!-- Rendered letters will go here -->
      </div>
      <div id="focus-reminder" class="absolute inset-0 bg-canvas/90 backdrop-blur-[2px] flex items-center justify-center text-sm font-sans text-body transition-opacity duration-300">
        Click here to focus and start typing
      </div>
    </div>

    <!-- Hidden input to capture keystrokes on mobile/desktop -->
    <input 
      type="text" 
      id="typing-input" 
      class="opacity-0 absolute -z-10" 
      autocomplete="off" 
      autocorrect="off" 
      autocapitalize="off" 
      spellcheck="false"
    />

    <!-- Stats Panel -->
    <div class="grid grid-cols-3 gap-4 mb-4">
      <div class="bg-canvas border border-hairline rounded p-3 text-center">
        <span class="text-[10px] font-mono text-mute uppercase tracking-widest block mb-1">Time</span>
        <span id="typing-time" class="text-xl font-semibold text-ink">0s</span>
      </div>
      <div class="bg-canvas border border-hairline rounded p-3 text-center">
        <span class="text-[10px] font-mono text-mute uppercase tracking-widest block mb-1">Speed</span>
        <span id="typing-wpm" class="text-xl font-semibold text-ink">0 WPM</span>
      </div>
      <div class="bg-canvas border border-hairline rounded p-3 text-center">
        <span class="text-[10px] font-mono text-mute uppercase tracking-widest block mb-1">Accuracy</span>
        <span id="typing-accuracy" class="text-xl font-semibold text-ink">100%</span>
      </div>
    </div>
  </div>

  <!-- History and Sparkline Box (Startup screen) -->
  <div id="typing-history-box" class="w-full bg-canvas-soft border border-hairline rounded-lg p-4 mb-6 text-left">
    <div class="flex justify-between items-center mb-2">
      <span class="text-[10px] font-mono text-mute uppercase tracking-widest">WPM Progress History</span>
      <span id="history-runs-count" class="text-[10px] font-mono text-mute">0 runs</span>
    </div>
    <div id="typing-sparkline-container" class="h-8 mb-3 flex items-center justify-center border border-hairline/50 rounded bg-canvas/40 px-2 overflow-hidden">
      <!-- SVG path injected here -->
      <span class="text-[10px] text-mute/50 font-mono">No run history yet</span>
    </div>
    <div id="typing-history-list" class="flex flex-col gap-1.5 max-h-20 overflow-y-auto pr-1">
      <!-- Last 3 runs rendered here -->
    </div>
  </div>

  <!-- Results State -->
  <div id="typing-results" class="hidden w-full flex flex-col items-center">
    <div class="w-16 h-16 rounded-full bg-link/10 flex items-center justify-center text-link mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
      </svg>
    </div>
    <h3 class="text-2xl md:text-3xl font-semibold text-ink mb-2">Sprint Completed!</h3>
    <p class="text-body text-sm mb-6 max-w-sm">You stayed focused, completed the writing, and kept scrolling at bay.</p>
    
    <div class="grid grid-cols-2 gap-4 w-full max-w-xs mb-8">
      <div class="bg-canvas-soft border border-hairline rounded p-4 text-center">
        <span class="text-[10px] font-mono text-mute uppercase tracking-widest block mb-1">Final WPM</span>
        <span id="final-wpm" class="text-2xl font-semibold text-ink">0</span>
      </div>
      <div class="bg-canvas-soft border border-hairline rounded p-4 text-center">
        <span class="text-[10px] font-mono text-mute uppercase tracking-widest block mb-1">Accuracy</span>
        <span id="final-accuracy" class="text-2xl font-semibold text-ink">100%</span>
      </div>
    </div>

    <Button id="typing-complete-btn" variant="success" class="w-48 !h-11 !text-sm">Complete →</Button>
  </div>
</div>

<style>
  .char-correct {
    color: var(--color-ink);
  }
  .char-incorrect {
    color: var(--color-error-deep);
    background-color: var(--color-error-soft);
    border-radius: 2px;
  }
  .char-active {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 600;
  }
</style>

<script>
  const quotes = [
    "The happiness of your life depends upon the quality of your thoughts.",
    "We suffer more often in imagination than in reality.",
    "The best way to predict the future is to create it.",
    "It is not that we have a short time to live, but that we waste a lot of it.",
    "Simplicity is the ultimate sophistication.",
    "You have power over your mind - not outside events. Realize this and you will find strength.",
    "Focus is a matter of deciding what things you're not going to do.",
    "The content you consume today dictates the thoughts you have tomorrow."
  ];

  const challengeQuotes = [
    "The key to growth is being comfortable with the uncomfortable.",
    "Energy flows where attention goes. Focus on what truly matters to you.",
    "Quiet minds are the ones that create the most beautiful ideas.",
    "You do not rise to the level of your goals. You fall to the level of your systems.",
    "The space between stimulus and response is where our freedom lies.",
    "Do not let the noise of others' opinions drown out your own inner voice.",
    "To pay attention is the highest form of generosity.",
    "True focus is not saying yes to one thing, but saying no to a hundred others."
  ];

  const ACHIEVEMENTS = [
    { id: 'speed_demon', title: 'Speed Demon', desc: 'Reach 60+ WPM in a typing sprint', cp: 10 },
    { id: 'sniper', title: 'Perfect Accuracy', desc: '100% accuracy on any typing sprint', cp: 15 },
    { id: 'sprint_regular', title: 'Habit Builder', desc: 'Complete 5 typing sprints in total', cp: 20 },
    { id: 'daily_striker', title: 'Daily Devotee', desc: 'Complete a Daily Challenge sprint', cp: 10 }
  ];

  const KEYS = {
    stats: 'escapebored_typing_stats'
  };

  let quote = "";
  let letters = [];
  let typedCount = 0;
  let errorCount = 0;
  let startTime = null;
  let timerInterval = null;
  let isStarted = false;
  let sprintDurationSeconds = 0;
  let isDailyChallenge = false;
  let lastUnlocks = [];

  const container = document.getElementById('quote-container');
  const quoteText = document.getElementById('quote-text');
  const inputEl = document.getElementById('typing-input') as HTMLInputElement;
  const focusReminder = document.getElementById('focus-reminder');
  const timeDisplay = document.getElementById('typing-time');
  const wpmDisplay = document.getElementById('typing-wpm');
  const accuracyDisplay = document.getElementById('typing-accuracy');

  const typingGameSection = document.getElementById('typing-game');
  const resultsSection = document.getElementById('typing-results');
  const finalWpm = document.getElementById('final-wpm');
  const finalAccuracy = document.getElementById('final-accuracy');
  const completeBtn = document.getElementById('typing-complete-btn');

  // Achievements Modal Nodes
  const trophyBtn = document.getElementById('typing-trophy-btn');
  const achievementsModal = document.getElementById('typing-achievements-modal');
  const achievementsCloseBtn = document.getElementById('achievements-close-btn');

  function getTodayString() {
    const today = new Date();
    return `${today.getFullYear()}-${(today.getMonth()+1).toString().padStart(2, '0')}-${today.getDate().toString().padStart(2, '0')}`;
  }

  function loadTypingStats() {
    const defaultStats = {
      personalBestWPM: 0,
      personalBestAccuracy: 0,
      streakCount: 0,
      lastPlayedDate: '',
      history: [],
      unlockedAchievements: []
    };
    try {
      const saved = localStorage.getItem(KEYS.stats);
      return saved ? JSON.parse(saved) : defaultStats;
    } catch (e) {
      return defaultStats;
    }
  }

  function saveTypingStats(stats) {
    try {
      localStorage.setItem(KEYS.stats, JSON.stringify(stats));
    } catch (e) {}
  }

  function renderHistoryAndPB() {
    const stats = loadTypingStats();
    
    // PB WPM
    const pbDisplayVal = document.getElementById('pb-wpm-val');
    if (pbDisplayVal) pbDisplayVal.textContent = stats.personalBestWPM.toString();

    // Runs Count
    const runsCount = document.getElementById('history-runs-count');
    if (runsCount) {
      runsCount.textContent = `${stats.history.length} ${stats.history.length === 1 ? 'run' : 'runs'}`;
    }

    const sparkline = document.getElementById('typing-sparkline-container');
    const historyList = document.getElementById('typing-history-list');

    if (stats.history.length === 0) {
      if (sparkline) sparkline.innerHTML = '<span class="text-[10px] text-mute/50 font-mono">No run history yet</span>';
      if (historyList) historyList.innerHTML = '<div class="text-xs text-mute/40 text-center py-2">Complete a sprint to see stats!</div>';
    } else {
      // Draw SVG Sparkline
      if (sparkline) {
        const wpms = stats.history.slice(-10).map(h => h.wpm);
        const maxWpm = Math.max(...wpms, 60);
        const minWpm = Math.min(...wpms, 0);
        const range = maxWpm - minWpm || 1;

        const width = 380;
        const height = 24;
        const padding = 2;

        const points = wpms.map((wpm, idx) => {
          const x = padding + (idx / (wpms.length - 1 || 1)) * (width - 2 * padding);
          const y = height - padding - ((wpm - minWpm) / range) * (height - 2 * padding);
          return `${x},${y}`;
        }).join(' ');

        sparkline.innerHTML = `
          <svg class="w-full h-6 stroke-link fill-none stroke-2" viewBox="0 0 ${width} ${height}">
            <polyline stroke-linecap="round" stroke-linejoin="round" points="${points}" />
          </svg>
        `;
      }

      // History List (last 3)
      if (historyList) {
        historyList.innerHTML = stats.history.slice(-3).reverse().map(h => {
          const date = new Date(h.timestamp);
          const timeLabel = `${date.toLocaleDateString()} ${date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}`;
          return `
            <div class="flex justify-between items-center text-[10px] py-1 border-b border-white/5">
              <span class="text-mute font-mono">${timeLabel}${h.isDailyChallenge ? ' (Challenge)' : ''}</span>
              <span class="font-semibold text-ink">${h.wpm} WPM / ${h.accuracy}% Acc</span>
            </div>
          `;
        }).join('');
      }
    }
  }

  function renderAchievements() {
    const stats = loadTypingStats();
    const listContainer = document.getElementById('achievements-list');
    if (!listContainer) return;

    listContainer.innerHTML = ACHIEVEMENTS.map(ach => {
      const isUnlocked = stats.unlockedAchievements.includes(ach.id);
      return `
        <div class="flex items-center gap-3 p-2.5 rounded border ${isUnlocked ? 'bg-white/5 border-white/10 text-white' : 'bg-black/20 border-white/5 text-white/40 opacity-50'}">
          <div class="text-xl">${isUnlocked ? '🏆' : '🔒'}</div>
          <div class="flex-1">
            <div class="font-semibold text-[11px] font-mono leading-tight">${ach.title}</div>
            <div class="text-[10px] text-white/50 mt-0.5 leading-tight">${ach.desc}</div>
          </div>
          <div class="font-mono text-[9px] font-semibold text-link">+${ach.cp} CP</div>
        </div>
      `;
    }).join('');
  }

  function checkAchievements(wpm, accuracy, stats) {
    const unlockedNow = [];
    if (wpm >= 60 && !stats.unlockedAchievements.includes('speed_demon')) {
      stats.unlockedAchievements.push('speed_demon');
      unlockedNow.push('speed_demon');
    }
    if (accuracy === 100 && !stats.unlockedAchievements.includes('sniper')) {
      stats.unlockedAchievements.push('sniper');
      unlockedNow.push('sniper');
    }
    if (stats.history.length >= 5 && !stats.unlockedAchievements.includes('sprint_regular')) {
      stats.unlockedAchievements.push('sprint_regular');
      unlockedNow.push('sprint_regular');
    }
    if (isDailyChallenge && !stats.unlockedAchievements.includes('daily_striker')) {
      stats.unlockedAchievements.push('daily_striker');
      unlockedNow.push('daily_striker');
    }
    return unlockedNow;
  }

  function initQuote() {
    const stats = loadTypingStats();
    const todayStr = getTodayString();
    
    // Check if daily challenge completed today
    const challengeDoneToday = stats.history.some(h => h.isDailyChallenge && h.timestamp.startsWith(todayStr));
    const badge = document.getElementById('daily-challenge-badge');

    if (!challengeDoneToday) {
      isDailyChallenge = true;
      const dayOfYear = Math.floor((new Date().getTime() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000);
      quote = challengeQuotes[dayOfYear % challengeQuotes.length];
      if (badge) {
        badge.classList.remove('hidden');
        badge.textContent = "Daily Challenge";
        badge.className = "text-[9px] font-semibold text-link bg-link/10 border border-link/25 px-1.5 py-0.5 rounded animate-pulse";
      }
    } else {
      isDailyChallenge = false;
      quote = quotes[Math.floor(Math.random() * quotes.length)];
      if (badge) {
        badge.classList.add('hidden');
      }
    }

    quoteText.innerHTML = '';
    letters = quote.split('').map((char) => {
      const span = document.createElement('span');
      span.textContent = char;
      span.className = 'text-mute opacity-60';
      quoteText.appendChild(span);
      return span;
    });
    typedCount = 0;
    errorCount = 0;
    isStarted = false;
    startTime = null;
    if (timerInterval) clearInterval(timerInterval);
    updateStats();
    
    // Set active class on the first character
    if (letters.length > 0) {
      letters[0].classList.add('char-active');
      letters[0].classList.remove('opacity-60');
    }

    renderHistoryAndPB();
    renderAchievements();
  }

  function updateStats() {
    let seconds = 0;
    if (startTime) {
      seconds = Math.round((Date.now() - startTime) / 1000);
    }
    timeDisplay.textContent = `${seconds}s`;
    
    const minutes = seconds / 60 || 1/60; // prevent division by zero
    // WPM calculation: (typed chars / 5) / minutes
    const wpm = Math.round((typedCount / 5) / minutes);
    wpmDisplay.textContent = `${wpm} WPM`;

    const totalTyped = typedCount + errorCount;
    const accuracy = totalTyped > 0 ? Math.round((typedCount / totalTyped) * 100) : 100;
    accuracyDisplay.textContent = `${accuracy}%`;
  }

  function handleInput(e) {
    const value = inputEl.value;
    inputEl.value = ''; // Reset input to read key-by-key
    if (!value) return;

    if (!isStarted) {
      isStarted = true;
      startTime = Date.now();
      timerInterval = setInterval(updateStats, 1000);
      document.getElementById('typing-history-box')?.classList.add('hidden');
    }

    const expected = quote[typedCount];
    const actual = value[value.length - 1]; // get the last character typed

    if (actual === expected) {
      letters[typedCount].className = 'char-correct';
      typedCount++;
      if (typedCount < letters.length) {
        letters[typedCount].className = 'char-active';
      } else {
        // Completed!
        finishSprint();
      }
    } else {
      // Incorrect
      errorCount++;
      letters[typedCount].className = 'char-incorrect char-active';
      // play a quick error sound (low buzzer tone) if audio allowed
      playTone(180, 'triangle', 0.1);
    }
    updateStats();
  }

  function playTone(freq, type = 'sine', duration = 0.1) {
    try {
      const tempCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = tempCtx.createOscillator();
      const gainNode = tempCtx.createGain();
      osc.type = type as any;
      osc.frequency.setValueAtTime(freq, tempCtx.currentTime);
      gainNode.gain.setValueAtTime(0.04, tempCtx.currentTime);
      gainNode.gain.exponentialRampToValueAtTime(0.0001, tempCtx.currentTime + duration);
      osc.connect(gainNode);
      gainNode.connect(tempCtx.destination);
      osc.start();
      osc.stop(tempCtx.currentTime + duration);
    } catch(e) {}
  }

  function finishSprint() {
    clearInterval(timerInterval);
    const elapsedSeconds = Math.round((Date.now() - startTime) / 1000);
    sprintDurationSeconds = elapsedSeconds;
    const minutes = elapsedSeconds / 60 || 1/60;
    const wpm = Math.round((typedCount / 5) / minutes);
    const totalTyped = typedCount + errorCount;
    const accuracy = totalTyped > 0 ? Math.round((typedCount / totalTyped) * 100) : 100;

    finalWpm.textContent = wpm.toString();
    finalAccuracy.textContent = `${accuracy}%`;

    const stats = loadTypingStats();
    
    // Save to history
    stats.history.push({
      timestamp: new Date().toISOString(),
      wpm: wpm,
      accuracy: accuracy,
      isDailyChallenge: isDailyChallenge
    });

    // Check PBs
    if (wpm > stats.personalBestWPM) {
      stats.personalBestWPM = wpm;
    }
    if (accuracy > stats.personalBestAccuracy) {
      stats.personalBestAccuracy = accuracy;
    }

    // Check unlocked achievements
    lastUnlocks = checkAchievements(wpm, accuracy, stats);
    saveTypingStats(stats);

    typingGameSection.classList.add('hidden');
    resultsSection.classList.remove('hidden');
    document.getElementById('typing-history-box')?.classList.remove('hidden');
    
    // Core success chime
    playTone(523.25, 'sine', 0.2); // C5
    setTimeout(() => playTone(659.25, 'sine', 0.2), 150); // E5
    setTimeout(() => playTone(783.99, 'sine', 0.4), 300); // G5

    // Achievements unlock effects
    if (lastUnlocks.length > 0) {
      setTimeout(() => playTone(1046.50, 'sine', 0.1), 500); // C6
      setTimeout(() => playTone(1318.51, 'sine', 0.1), 600); // E6
      setTimeout(() => playTone(1567.98, 'sine', 0.3), 700); // G6
      
      const resultsTitle = document.querySelector('#typing-results h3');
      if (resultsTitle) {
        resultsTitle.innerHTML = `Sprint Completed!<br/><span class="text-xs text-link font-semibold animate-pulse">🏆 ${lastUnlocks.length} Achievement(s) Unlocked!</span>`;
      }
    } else {
      const resultsTitle = document.querySelector('#typing-results h3');
      if (resultsTitle) {
        resultsTitle.innerHTML = `Sprint Completed!`;
      }
    }
  }

  // Event Listeners
  container.addEventListener('click', () => {
    inputEl.focus();
  });

  inputEl.addEventListener('focus', () => {
    focusReminder.classList.add('opacity-0', 'pointer-events-none');
  });

  inputEl.addEventListener('blur', () => {
    focusReminder.classList.remove('opacity-0', 'pointer-events-none');
  });

  inputEl.addEventListener('input', handleInput);

  // Prevent backspace from resetting text
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Backspace') {
      e.preventDefault();
    }
  });

  completeBtn.addEventListener('click', () => {
    const wpmVal = parseInt(finalWpm.textContent || '0');
    const accVal = parseInt(finalAccuracy.textContent || '100');
    
    // Calculate points: base 10 points + scaling with speed and accuracy
    let points = Math.round(10 + (wpmVal / 10) * (accVal / 100));
    let activityName = isDailyChallenge ? `Daily Typing Challenge (${wpmVal} WPM)` : `Typing Sprint (${wpmVal} WPM)`;

    if (isDailyChallenge) {
      points += 10; // +10 CP Daily Challenge Bonus
    }

    // Award bonus achievements points
    const stats = loadTypingStats();
    let achievementBonusPoints = lastUnlocks.reduce((sum, achId) => {
      const ach = ACHIEVEMENTS.find(a => a.id === achId);
      return sum + (ach ? ach.cp : 0);
    }, 0);

    points += achievementBonusPoints;
    if (lastUnlocks.length > 0) {
      activityName += ` + ${lastUnlocks.length} Achievement${lastUnlocks.length > 1 ? 's' : ''}!`;
    }

    const event = new CustomEvent('activityCompleted', { 
      detail: { 
        points: points, 
        activityName: activityName,
        duration: Math.max(1, Math.round(sprintDurationSeconds / 60))
      } 
    });
    window.dispatchEvent(event);
  });

  // Modal actions
  trophyBtn.addEventListener('click', () => {
    renderAchievements();
    achievementsModal.classList.remove('hidden');
    achievementsModal.classList.add('animate-in', 'fade-in', 'zoom-in-95', 'duration-200');
  });

  achievementsCloseBtn.addEventListener('click', () => {
    achievementsModal.classList.add('hidden');
  });

  // Init
  initQuote();

  window.addEventListener('betterthings_tool_reset', () => {
    initQuote();
    typingGameSection.classList.remove('hidden');
    resultsSection.classList.add('hidden');
    document.getElementById('typing-history-box')?.classList.remove('hidden');
  });
</script>


