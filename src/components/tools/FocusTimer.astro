---
import Button from '../Button.astro';
---

<div class="flex flex-col items-center justify-center p-6 text-center w-full max-w-md mx-auto" data-tool="focustimer">
  <h4 class="text-xs font-mono text-mute uppercase tracking-widest mb-4">Focus Sprint Timer</h4>

  <!-- Tab Switcher -->
  <div class="flex bg-canvas-soft border border-hairline p-1 rounded-lg w-full mb-6 z-10">
    <button id="focus-tab-timer" class="flex-1 py-1.5 text-xs font-medium rounded-md bg-white/10 text-white cursor-pointer transition-all">Timer</button>
    <button id="focus-tab-stats" class="flex-1 py-1.5 text-xs font-medium rounded-md text-mute hover:text-white cursor-pointer transition-all">Stats</button>
  </div>

  <!-- Timer progress container -->
  <div class="relative w-64 h-64 flex items-center justify-center mb-8">
    <svg class="w-full h-full transform -rotate-90" viewBox="0 0 200 200">
      <!-- Background Circle -->
      <circle 
        cx="100" 
        cy="100" 
        r="80" 
        fill="transparent" 
        stroke="var(--color-hairline)" 
        stroke-width="6"
      />
      <!-- Progress Circle -->
      <circle 
        id="timer-progress" 
        cx="100" 
        cy="100" 
        r="80" 
        fill="transparent" 
        stroke="var(--color-primary)" 
        stroke-width="6" 
        stroke-dasharray="502.6" 
        stroke-dashoffset="0" 
        stroke-linecap="round"
        class="transition-all duration-1000 ease-linear"
      />
    </svg>
    <div class="absolute flex flex-col items-center justify-center">
      <span id="timer-display" class="text-4xl font-semibold tracking-tight-md text-ink">05:00</span>
      <span id="timer-status" class="text-[11px] font-mono text-mute mt-1 uppercase tracking-wider">Stay Focused</span>
    </div>
  </div>

  <!-- Ambient Sound Controls -->
  <div class="w-full bg-canvas-soft-2 border border-hairline rounded-lg p-4 mb-8">
    <span class="text-xs font-mono text-mute block mb-3 uppercase tracking-widest text-left">Synthesized Ambient Sound</span>
    <div class="grid grid-cols-4 gap-2">
      <button id="sound-none" class="sound-btn py-1.5 px-2 text-xs rounded border border-hairline bg-canvas font-medium text-ink hover:bg-canvas-soft transition-all active-sound" data-sound="none">Off</button>
      <button id="sound-rain" class="sound-btn py-1.5 px-2 text-xs rounded border border-hairline bg-canvas font-medium text-mute hover:bg-canvas-soft transition-all" data-sound="rain">Rain</button>
      <button id="sound-ocean" class="sound-btn py-1.5 px-2 text-xs rounded border border-hairline bg-canvas font-medium text-mute hover:bg-canvas-soft transition-all" data-sound="ocean">Waves</button>
      <button id="sound-drone" class="sound-btn py-1.5 px-2 text-xs rounded border border-hairline bg-canvas font-medium text-mute hover:bg-canvas-soft transition-all" data-sound="drone">Drone</button>
    </div>
  </div>

  <!-- Presets -->
  <div class="flex gap-2 mb-8" id="preset-controls">
    <button class="preset-btn px-4 py-1 text-xs rounded-pill border border-hairline-strong font-mono bg-canvas text-ink font-semibold" data-duration="120">2 Min</button>
    <button class="preset-btn px-4 py-1 text-xs rounded-pill border border-hairline font-mono bg-canvas text-mute hover:border-hairline-strong" data-duration="300">5 Min</button>
    <button class="preset-btn px-4 py-1 text-xs rounded-pill border border-hairline font-mono bg-canvas text-mute hover:border-hairline-strong" data-duration="600">10 Min</button>
  </div>

  <!-- Stats Subview Panel -->
  <div id="focus-stats-panel" class="hidden w-full flex flex-col gap-6 text-left mb-6">
    <!-- Today's Goal progress card -->
    <div class="bg-canvas-soft border border-hairline rounded-lg p-4 flex items-center gap-4">
      <div class="relative w-14 h-14 flex items-center justify-center flex-shrink-0">
        <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
          <circle cx="18" cy="18" r="16" fill="none" stroke="var(--color-hairline)" stroke-width="3" />
          <circle id="focus-goal-ring" cx="18" cy="18" r="16" fill="none" stroke="var(--color-link)" stroke-width="3" stroke-dasharray="100" stroke-dashoffset="100" stroke-linecap="round" />
        </svg>
        <span id="focus-goal-percentage" class="absolute text-[10px] font-mono font-semibold text-white">0%</span>
      </div>
      <div>
        <h5 class="text-xs font-semibold text-white leading-tight">Daily Focus Target</h5>
        <p id="focus-goal-text" class="text-[10px] text-mute mt-0.5">0 of 25 minutes focused today.</p>
      </div>
    </div>

    <!-- Weekly Trend SVG Bar Chart -->
    <div class="bg-canvas-soft border border-hairline rounded-lg p-4">
      <span class="text-[10px] font-mono text-mute uppercase tracking-widest block mb-3">7-Day Focus Trend</span>
      <div id="focus-weekly-chart" class="h-20 flex items-end justify-between gap-1.5 px-2">
        <!-- Renders 7 SVG vertical bars dynamically -->
      </div>
    </div>

    <!-- Ambient Mix Distribution -->
    <div class="bg-canvas-soft border border-hairline rounded-lg p-4">
      <span class="text-[10px] font-mono text-mute uppercase tracking-widest block mb-3">Ambient Sound Mix</span>
      <div class="flex flex-col gap-2">
        <div class="flex justify-between text-[10px] text-mute">
          <span>Rain</span>
          <span id="ambient-dist-rain">0%</span>
        </div>
        <div class="w-full h-1.5 bg-hairline rounded-full overflow-hidden">
          <div id="ambient-bar-rain" class="h-full bg-link w-0 transition-all duration-500"></div>
        </div>

        <div class="flex justify-between text-[10px] text-mute mt-1">
          <span>Waves</span>
          <span id="ambient-dist-ocean">0%</span>
        </div>
        <div class="w-full h-1.5 bg-hairline rounded-full overflow-hidden">
          <div id="ambient-bar-ocean" class="h-full bg-success w-0 transition-all duration-500"></div>
        </div>

        <div class="flex justify-between text-[10px] text-mute mt-1">
          <span>Drone</span>
          <span id="ambient-dist-drone">0%</span>
        </div>
        <div class="w-full h-1.5 bg-hairline rounded-full overflow-hidden">
          <div id="ambient-bar-drone" class="h-full bg-warning w-0 transition-all duration-500"></div>
        </div>
      </div>
    </div>

    <!-- Recent Session Logs list -->
    <div class="flex flex-col gap-2">
      <span class="text-[10px] font-mono text-mute uppercase tracking-widest">Recent Focus Sprints</span>
      <div id="focus-history-list" class="flex flex-col gap-2 max-h-36 overflow-y-auto pr-1">
        <!-- Rendered session logs -->
      </div>
    </div>
  </div>

  <div class="flex gap-4 w-full justify-center">
    <Button id="timer-toggle" variant="primary" class="w-32 !h-11 !text-sm">Start Focus</Button>
    <Button id="timer-reset" variant="secondary" class="w-32 !h-11 !text-sm">Reset</Button>
    <Button id="timer-complete-btn" variant="success" class="w-36 !h-11 !text-sm hidden">Complete →</Button>
  </div>
</div>

<style>
  .active-sound {
    background-color: var(--color-primary) !important;
    color: var(--color-on-primary) !important;
    border-color: var(--color-primary) !important;
  }
</style>

<script>
  let totalSeconds = 120; // default preset selected (2 min)
  let secondsLeft = 120;
  let timerInterval = null;
  let timerRunning = false;

  // Web Audio Context & Nodes
  let audioCtx = null;
  let currentSound = 'none';
  let noiseNode = null;
  let rainFilter = null;
  let wavesFilter = null;
  let wavesGain = null;
  let droneOscillators = [];
  let droneGain = null;
  let modulator = null;

  const display = document.getElementById('timer-display');
  const progressCircle = document.getElementById('timer-progress') as unknown as SVGCircleElement;
  const toggleBtn = document.getElementById('timer-toggle');
  const resetBtn = document.getElementById('timer-reset');
  const statusDisplay = document.getElementById('timer-status');
  const completeBtn = document.getElementById('timer-complete-btn');

  // Tab Switching Elements
  const tabTimer = document.getElementById('focus-tab-timer');
  const tabStats = document.getElementById('focus-tab-stats');
  const statsPanel = document.getElementById('focus-stats-panel');
  const timerCircle = progressCircle.parentElement.parentElement; // SVG ring
  const ambientSoundsBox = document.querySelector('[data-tool="focustimer"] .bg-canvas-soft-2');
  const presetsBox = document.getElementById('preset-controls');
  const controlsBox = toggleBtn.parentElement;

  // Circle circum = 2 * PI * r = 2 * 3.14159 * 80 = 502.65
  const circumference = 502.65;

  const FOCUS_KEYS = {
    history: 'escapebored_focus_history'
  };

  function setProgress(percent) {
    const offset = circumference - (percent / 100) * circumference;
    progressCircle.style.strokeDashoffset = offset.toString();
  }

  function updateDisplay() {
    const mins = Math.floor(secondsLeft / 60);
    const secs = secondsLeft % 60;
    display.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
    const percent = ((totalSeconds - secondsLeft) / totalSeconds) * 100;
    setProgress(percent);
  }

  function getTodayString() {
    const today = new Date();
    return `${today.getFullYear()}-${(today.getMonth()+1).toString().padStart(2, '0')}-${today.getDate().toString().padStart(2, '0')}`;
  }

  function getPastDateString(daysAgo) {
    const d = new Date();
    d.setDate(d.getDate() - daysAgo);
    return `${d.getFullYear()}-${(d.getMonth()+1).toString().padStart(2, '0')}-${d.getDate().toString().padStart(2, '0')}`;
  }

  function logFocusSession(minutes, sound) {
    let historyList = [];
    try {
      const saved = localStorage.getItem(FOCUS_KEYS.history);
      if (saved) historyList = JSON.parse(saved);
    } catch(e){}

    historyList.push({
      timestamp: new Date().toISOString(),
      durationMinutes: minutes,
      presetSelected: `${minutes} Min`,
      ambientSoundUsed: sound
    });

    try {
      localStorage.setItem(FOCUS_KEYS.history, JSON.stringify(historyList));
    } catch(e){}
  }

  function renderFocusStats() {
    let historyList = [];
    try {
      const saved = localStorage.getItem(FOCUS_KEYS.history);
      if (saved) historyList = JSON.parse(saved);
    } catch(e){}

    const todayStr = getTodayString();
    
    // 1. Daily goal progress (25 minutes)
    const todayMinutes = historyList
      .filter(s => s.timestamp.startsWith(todayStr))
      .reduce((sum, s) => sum + s.durationMinutes, 0);

    const goal = 25;
    const goalPercent = Math.min(Math.round((todayMinutes / goal) * 100), 100);
    
    const goalRing = document.getElementById('focus-goal-ring') as unknown as SVGCircleElement;
    const goalPercentEl = document.getElementById('focus-goal-percentage');
    const goalText = document.getElementById('focus-goal-text');

    if (goalRing) {
      const circum = 100.5; // 2 * PI * 16
      const offset = circum - (goalPercent / 100) * circum;
      goalRing.style.strokeDashoffset = offset.toString();
    }
    if (goalPercentEl) goalPercentEl.textContent = `${goalPercent}%`;
    if (goalText) goalText.textContent = `${todayMinutes} of ${goal} minutes focused today.`;

    // 2. Weekly Trend Bar Chart
    const weeklyChart = document.getElementById('focus-weekly-chart');
    if (weeklyChart) {
      const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      let barsHTML = '';
      
      const dayValues = [];
      for (let i = 6; i >= 0; i--) {
        const dateStr = getPastDateString(i);
        const dayMins = historyList
          .filter(s => s.timestamp.startsWith(dateStr))
          .reduce((sum, s) => sum + s.durationMinutes, 0);
        
        const dateObj = new Date();
        dateObj.setDate(dateObj.getDate() - i);
        const dayName = dayNames[dateObj.getDay()];
        dayValues.push({ name: dayName, mins: dayMins });
      }

      const maxMins = Math.max(...dayValues.map(d => d.mins), 25);

      dayValues.forEach(day => {
        const heightPercent = Math.min(Math.round((day.mins / maxMins) * 100), 100);
        barsHTML += `
          <div class="flex-1 flex flex-col items-center gap-1">
            <span class="text-[8px] font-mono text-white/50">${day.mins}m</span>
            <div class="w-full bg-link/10 border border-link/25 rounded-t" style="height: ${Math.max(4, heightPercent * 0.5)}px; background-color: rgba(0, 112, 243, ${0.1 + (heightPercent/100)*0.5})"></div>
            <span class="text-[8px] font-mono text-mute mt-1">${day.name}</span>
          </div>
        `;
      });
      weeklyChart.innerHTML = barsHTML;
    }

    // 3. Ambient sound distribution
    const sessionsWithSound = historyList.filter(s => s.ambientSoundUsed && s.ambientSoundUsed !== 'none');
    const totalWithSound = sessionsWithSound.length || 1;
    
    const countRain = sessionsWithSound.filter(s => s.ambientSoundUsed === 'rain').length;
    const countOcean = sessionsWithSound.filter(s => s.ambientSoundUsed === 'ocean').length;
    const countDrone = sessionsWithSound.filter(s => s.ambientSoundUsed === 'drone').length;

    const pctRain = Math.round((countRain / totalWithSound) * 100);
    const pctOcean = Math.round((countOcean / totalWithSound) * 100);
    const pctDrone = Math.round((countDrone / totalWithSound) * 100);

    const distRain = document.getElementById('ambient-dist-rain');
    const distOcean = document.getElementById('ambient-dist-ocean');
    const distDrone = document.getElementById('ambient-dist-drone');
    
    const barRain = document.getElementById('ambient-bar-rain');
    const barOcean = document.getElementById('ambient-bar-ocean');
    const barDrone = document.getElementById('ambient-bar-drone');

    if (distRain) distRain.textContent = `${pctRain}%`;
    if (distOcean) distOcean.textContent = `${pctOcean}%`;
    if (distDrone) distDrone.textContent = `${pctDrone}%`;

    if (barRain) barRain.style.width = `${pctRain}%`;
    if (barOcean) barOcean.style.width = `${pctOcean}%`;
    if (barDrone) barDrone.style.width = `${pctDrone}%`;

    // 4. Recent session list
    const historyListEl = document.getElementById('focus-history-list');
    if (historyListEl) {
      if (historyList.length === 0) {
        historyListEl.innerHTML = '<div class="text-[10px] text-mute/40 text-center py-4 border border-dashed border-hairline rounded">No sessions recorded yet. Start a focus sprint!</div>';
      } else {
        historyListEl.innerHTML = historyList.slice(-5).reverse().map(s => {
          const date = new Date(s.timestamp);
          const timeLabel = `${date.toLocaleDateString()} ${date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}`;
          const soundLabel = s.ambientSoundUsed === 'none' ? 'Silent' : s.ambientSoundUsed.charAt(0).toUpperCase() + s.ambientSoundUsed.slice(1);
          return `
            <div class="flex justify-between items-center text-[10px] p-2 bg-black/10 border border-white/5 rounded">
              <div class="flex flex-col">
                <span class="font-medium text-white">⏱️ Focused for ${s.durationMinutes} Min</span>
                <span class="text-[8px] font-mono text-white/45 mt-0.5">${timeLabel} — Sound: ${soundLabel}</span>
              </div>
            </div>
          `;
        }).join('');
      }
    }
  }

  // Tab Toggles Listeners
  tabTimer.addEventListener('click', () => {
    tabTimer.classList.add('bg-white/10', 'text-white');
    tabTimer.classList.remove('text-mute');
    tabStats.classList.remove('bg-white/10', 'text-white');
    tabStats.classList.add('text-mute');

    statsPanel.classList.add('hidden');
    timerCircle.classList.remove('hidden');
    ambientSoundsBox.classList.remove('hidden');
    presetsBox.classList.remove('hidden');
    controlsBox.classList.remove('hidden');
  });

  tabStats.addEventListener('click', () => {
    tabStats.classList.add('bg-white/10', 'text-white');
    tabStats.classList.remove('text-mute');
    tabTimer.classList.remove('bg-white/10', 'text-white');
    tabTimer.classList.add('text-mute');

    timerCircle.classList.add('hidden');
    ambientSoundsBox.classList.add('hidden');
    presetsBox.classList.add('hidden');
    controlsBox.classList.add('hidden');

    renderFocusStats();
    statsPanel.classList.remove('hidden');
  });

  function tick() {
    if (secondsLeft > 0) {
      secondsLeft--;
      updateDisplay();
    } else {
      clearInterval(timerInterval);
      timerInterval = null;
      timerRunning = false;
      statusDisplay.textContent = "Focus Completed";
      statusDisplay.className = "text-[11px] font-mono text-link mt-1 uppercase tracking-wider font-semibold";
      toggleBtn.classList.add('hidden');
      resetBtn.classList.add('hidden');
      completeBtn.classList.remove('hidden');
      stopAudio();
      
      // Log session in history
      logFocusSession(Math.round(totalSeconds / 60), currentSound);

      playChime(659.25, 0.5); // E5
      setTimeout(() => playChime(880, 0.8), 200); // A5
    }
  }

  function playChime(freq, duration = 0.5) {
    try {
      const tempCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = tempCtx.createOscillator();
      const gainNode = tempCtx.createGain();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(freq, tempCtx.currentTime);
      gainNode.gain.setValueAtTime(0.05, tempCtx.currentTime);
      gainNode.gain.exponentialRampToValueAtTime(0.0001, tempCtx.currentTime + duration);
      osc.connect(gainNode);
      gainNode.connect(tempCtx.destination);
      osc.start();
      osc.stop(tempCtx.currentTime + duration);
    } catch(e) {}
  }

  // Synthesize White Noise Buffer
  function createNoiseBuffer() {
    const bufferSize = 2 * audioCtx.sampleRate;
    const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
    const output = noiseBuffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      output[i] = Math.random() * 2 - 1;
    }
    return noiseBuffer;
  }

  function initAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    }
  }

  function startAudio() {
    if (currentSound === 'none') return;
    initAudio();
    
    if (audioCtx.state === 'suspended') {
      audioCtx.resume();
    }

    stopAudio(); // Reset any playing sounds

    if (currentSound === 'rain') {
      // Synthesize Rain: low-pass filtered white noise
      const buffer = createNoiseBuffer();
      noiseNode = audioCtx.createBufferSource();
      noiseNode.buffer = buffer;
      noiseNode.loop = true;

      rainFilter = audioCtx.createBiquadFilter();
      rainFilter.type = 'lowpass';
      rainFilter.frequency.setValueAtTime(450, audioCtx.currentTime);

      const rainGain = audioCtx.createGain();
      rainGain.gain.setValueAtTime(0.3, audioCtx.currentTime);

      noiseNode.connect(rainFilter);
      rainFilter.connect(rainGain);
      rainGain.connect(audioCtx.destination);
      noiseNode.start(0);

    } else if (currentSound === 'ocean') {
      // Synthesize Ocean Waves: modulated lowpass filter on noise
      const buffer = createNoiseBuffer();
      noiseNode = audioCtx.createBufferSource();
      noiseNode.buffer = buffer;
      noiseNode.loop = true;

      wavesFilter = audioCtx.createBiquadFilter();
      wavesFilter.type = 'lowpass';
      wavesFilter.frequency.setValueAtTime(250, audioCtx.currentTime);

      wavesGain = audioCtx.createGain();
      wavesGain.gain.setValueAtTime(0.1, audioCtx.currentTime);

      // Modulator for swell: LFO that changes cutoff
      modulator = audioCtx.createOscillator();
      modulator.frequency.setValueAtTime(0.08, audioCtx.currentTime); // slow speed
      const modGain = audioCtx.createGain();
      modGain.gain.setValueAtTime(150, audioCtx.currentTime); // amplitude of frequency sweep

      modulator.connect(modGain);
      modGain.connect(wavesFilter.frequency); // modulating cutoff frequency

      // Also modulate volume slightly
      const gainMod = audioCtx.createGain();
      gainMod.gain.setValueAtTime(0.15, audioCtx.currentTime);
      modulator.connect(gainMod);
      gainMod.connect(wavesGain.gain);

      noiseNode.connect(wavesFilter);
      wavesFilter.connect(wavesGain);
      wavesGain.connect(audioCtx.destination);
      
      modulator.start(0);
      noiseNode.start(0);

    } else if (currentSound === 'drone') {
      // Synthesize Cozy Lofi Drone: deep chord harmonics
      droneGain = audioCtx.createGain();
      droneGain.gain.setValueAtTime(0.08, audioCtx.currentTime);
      
      const frequencies = [130.81, 196.00, 261.63, 329.63]; // C3, G3, C4, E4 (major chord)
      droneOscillators = frequencies.map((freq, idx) => {
        const osc = audioCtx.createOscillator();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq + (Math.random() - 0.5) * 0.5, audioCtx.currentTime); // slight detuning
        
        // Tremolo LFO for rich texture
        const tremolo = audioCtx.createOscillator();
        tremolo.frequency.setValueAtTime(0.2 + idx * 0.1, audioCtx.currentTime);
        const tremGain = audioCtx.createGain();
        tremGain.gain.setValueAtTime(0.02, audioCtx.currentTime);
        
        const oscGain = audioCtx.createGain();
        oscGain.gain.setValueAtTime(0.2, audioCtx.currentTime);
        
        tremolo.connect(tremGain);
        tremGain.connect(oscGain.gain);
        
        osc.connect(oscGain);
        oscGain.connect(droneGain);
        
        tremolo.start(0);
        osc.start(0);
        
        return { osc, tremolo };
      });
      
      // Lowpass to make it super warm
      const droneFilter = audioCtx.createBiquadFilter();
      droneFilter.type = 'lowpass';
      droneFilter.frequency.setValueAtTime(300, audioCtx.currentTime);
      
      droneGain.connect(droneFilter);
      droneFilter.connect(audioCtx.destination);
    }
  }

  function stopAudio() {
    if (noiseNode) {
      try { noiseNode.stop(); } catch(e){}
      noiseNode.disconnect();
      noiseNode = null;
    }
    if (modulator) {
      try { modulator.stop(); } catch(e){}
      modulator.disconnect();
      modulator = null;
    }
    if (droneOscillators.length > 0) {
      droneOscillators.forEach(({ osc, tremolo }) => {
        try { osc.stop(); tremolo.stop(); } catch(e){}
        osc.disconnect();
        tremolo.disconnect();
      });
      droneOscillators = [];
    }
  }

  // Presets and Buttons
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (timerRunning) return;
      document.querySelectorAll('.preset-btn').forEach(b => {
        b.classList.remove('border-hairline-strong', 'text-ink', 'font-semibold');
        b.classList.add('border-hairline', 'text-mute');
      });
      btn.classList.add('border-hairline-strong', 'text-ink', 'font-semibold');
      btn.classList.remove('border-hairline', 'text-mute');

      totalSeconds = parseInt(btn.getAttribute('data-duration'));
      secondsLeft = totalSeconds;
      updateDisplay();
    });
  });

  // Sound select logic
  document.querySelectorAll('.sound-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sound-btn').forEach(b => b.classList.remove('active-sound'));
      btn.classList.add('active-sound');
      currentSound = btn.getAttribute('data-sound');
      
      if (timerRunning) {
        startAudio();
      }
    });
  });

  toggleBtn.addEventListener('click', () => {
    if (timerRunning) {
      // Pause
      clearInterval(timerInterval);
      timerInterval = null;
      timerRunning = false;
      toggleBtn.textContent = "Resume Focus";
      toggleBtn.classList.remove('bg-canvas-soft-2', 'border', 'border-hairline', 'text-ink');
      toggleBtn.classList.add('bg-primary');
      statusDisplay.textContent = "Paused";
      stopAudio();
    } else {
      // Start
      initAudio();
      timerRunning = true;
      toggleBtn.textContent = "Pause Focus";
      toggleBtn.classList.remove('bg-primary');
      toggleBtn.classList.add('bg-canvas-soft-2', 'border', 'border-hairline', 'text-ink');
      statusDisplay.textContent = "Stay Focused";
      timerInterval = setInterval(tick, 1000);
      startAudio();
    }
  });

  resetBtn.addEventListener('click', () => {
    clearInterval(timerInterval);
    timerInterval = null;
    timerRunning = false;
    secondsLeft = totalSeconds;
    toggleBtn.textContent = "Start Focus";
    toggleBtn.classList.remove('bg-canvas-soft-2', 'border', 'border-hairline', 'text-ink', 'hidden');
    toggleBtn.classList.add('bg-primary');
    resetBtn.classList.remove('hidden');
    completeBtn.classList.add('hidden');
    statusDisplay.textContent = "Stay Focused";
    updateDisplay();
    stopAudio();
  });

  completeBtn.addEventListener('click', () => {
    const points = Math.round(totalSeconds / 10); // 1 point per 10s focused
    const event = new CustomEvent('activityCompleted', { 
      detail: { 
        points: points, 
        activityName: `Focus Sprint (${Math.round(totalSeconds/60)} Min)`,
        duration: Math.round(totalSeconds / 60)
      } 
    });
    window.dispatchEvent(event);
  });

  window.addEventListener('betterthings_tool_reset', () => {
    clearInterval(timerInterval);
    timerInterval = null;
    timerRunning = false;
    secondsLeft = totalSeconds;
    toggleBtn.textContent = "Start Focus";
    toggleBtn.classList.remove('bg-canvas-soft-2', 'border', 'border-hairline', 'text-ink', 'hidden');
    toggleBtn.classList.add('bg-primary');
    resetBtn.classList.remove('hidden');
    completeBtn.classList.add('hidden');
    statusDisplay.textContent = "Stay Focused";
    updateDisplay();
    stopAudio();
    
    // Reset active sound tab to None
    document.querySelectorAll('.sound-btn').forEach(b => b.classList.remove('active-sound'));
    document.getElementById('sound-none').classList.add('active-sound');
    currentSound = 'none';
  });
</script>
