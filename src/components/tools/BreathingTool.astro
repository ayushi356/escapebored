---
import Button from '../Button.astro';
---

<div class="flex flex-col items-center justify-center p-6 text-center w-full max-w-md mx-auto" data-tool="breathing">
  <h4 class="text-xs font-mono text-mute uppercase tracking-widest mb-6">Box Breathing — 1 Minute to Calm</h4>
  
  <!-- Breath circle container -->
  <div class="relative w-64 h-64 flex items-center justify-center mb-8">
    <div id="breath-circle" class="absolute w-48 h-48 rounded-full border border-hairline bg-canvas-soft-2 flex items-center justify-center">
      <!-- Outer ripple -->
      <div id="breath-ripple" class="absolute inset-0 rounded-full border border-link/20 scale-100 opacity-0 transition-all duration-[4000ms] ease-in-out"></div>
      <!-- Inner expansion -->
      <div id="breath-inner" class="absolute inset-2 rounded-full bg-link/5 scale-50 transition-all duration-[4000ms] ease-in-out"></div>
    </div>
    <div class="z-10 flex flex-col items-center justify-center pointer-events-none select-none">
      <span id="breath-instruction" class="text-3xl font-semibold text-ink tracking-tight-md">Ready</span>
      <span id="breath-timer" class="text-xs font-mono text-mute mt-1">4 seconds per step</span>
    </div>
  </div>

  <!-- Progress dots -->
  <div class="flex flex-col items-center gap-2 mb-8">
    <div class="flex gap-2" id="cycle-dots">
      <div class="w-2 h-2 rounded-full border border-hairline-strong bg-transparent transition-colors duration-300" data-dot="1"></div>
      <div class="w-2 h-2 rounded-full border border-hairline-strong bg-transparent transition-colors duration-300" data-dot="2"></div>
      <div class="w-2 h-2 rounded-full border border-hairline-strong bg-transparent transition-colors duration-300" data-dot="3"></div>
      <div class="w-2 h-2 rounded-full border border-hairline-strong bg-transparent transition-colors duration-300" data-dot="4"></div>
    </div>
    <span id="cycles-count" class="text-[10px] font-mono text-mute">Cycle 0 of 4</span>
  </div>

  <div class="flex gap-4 w-full justify-center">
    <Button id="breath-toggle" variant="primary" class="w-32 !h-11 !text-sm">Start</Button>
    <Button id="breath-complete-btn" variant="success" class="w-36 !h-11 !text-sm hidden">Complete →</Button>
  </div>
</div>

<script>
  let intervalId = null;
  let audioCtx = null;
  let isRunning = false;
  let step = 0; // 0: inhale, 1: hold, 2: exhale, 3: hold
  let timeLeft = 4;
  let cyclesCompleted = 0;
  const targetCycles = 4;

  const circle = document.getElementById('breath-circle');
  const inner = document.getElementById('breath-inner');
  const ripple = document.getElementById('breath-ripple');
  const instruction = document.getElementById('breath-instruction');
  const timer = document.getElementById('breath-timer');
  const toggleBtn = document.getElementById('breath-toggle');
  const completeBtn = document.getElementById('breath-complete-btn');
  const cycleCountText = document.getElementById('cycles-count');

  function initAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    }
  }

  function playChime(freq, duration = 0.4) {
    if (!audioCtx) return;
    try {
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      const osc = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
      gainNode.gain.setValueAtTime(0.04, audioCtx.currentTime);
      gainNode.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
      osc.connect(gainNode);
      gainNode.connect(audioCtx.destination);
      osc.start();
      osc.stop(audioCtx.currentTime + duration);
    } catch (e) {
      console.warn("Audio Context error:", e);
    }
  }

  function tick() {
    timeLeft--;
    
    if (timeLeft <= 0) {
      // Move to next step
      step = (step + 1) % 4;
      timeLeft = 4;
      
      if (step === 0) {
        cyclesCompleted++;
        updateCycles();
      }
      
      updateStepVisuals();
    } else {
      timer.textContent = `${timeLeft}s`;
    }
  }

  function updateCycles() {
    cycleCountText.textContent = `Cycle ${cyclesCompleted} of ${targetCycles}`;
    const dot = document.querySelector(`[data-dot="${cyclesCompleted}"]`);
    if (dot) {
      dot.classList.remove('bg-transparent');
      dot.classList.add('bg-link');
    }

    if (cyclesCompleted >= targetCycles) {
      completeBtn.classList.remove('hidden');
      toggleBtn.classList.add('hidden');
      stopBreathing();
      playChime(880, 0.6); // Final high chime
      instruction.textContent = "Done";
      timer.textContent = "Feel the calm.";
    }
  }

  function updateStepVisuals() {
    timer.textContent = `${timeLeft}s`;
    
    // Smooth custom transition properties based on steps
    if (step === 0) {
      // Inhale
      instruction.textContent = "Inhale";
      instruction.className = "text-3xl font-semibold text-link tracking-tight-md";
      
      inner.style.transition = "transform 4000ms cubic-bezier(0.4, 0, 0.2, 1), opacity 4000ms";
      inner.style.transform = "scale(1)";
      inner.style.opacity = "1";
      
      ripple.style.transition = "none";
      ripple.style.transform = "scale(1)";
      ripple.style.opacity = "0.4";
      setTimeout(() => {
        ripple.style.transition = "transform 4000ms cubic-bezier(0.1, 0.8, 0.3, 1), opacity 4000ms";
        ripple.style.transform = "scale(1.3)";
        ripple.style.opacity = "0";
      }, 50);

      playChime(523.25, 0.3); // C5
    } else if (step === 1) {
      // Hold
      instruction.textContent = "Hold";
      instruction.className = "text-3xl font-semibold text-warning-deep tracking-tight-md";
      
      inner.style.transition = "transform 4000ms linear";
      inner.style.transform = "scale(1)";
      
      playChime(587.33, 0.3); // D5
    } else if (step === 2) {
      // Exhale
      instruction.textContent = "Exhale";
      instruction.className = "text-3xl font-semibold text-link-deep tracking-tight-md";
      
      inner.style.transition = "transform 4000ms cubic-bezier(0.4, 0, 0.2, 1), opacity 4000ms";
      inner.style.transform = "scale(0.5)";
      inner.style.opacity = "0.5";
      
      playChime(440.00, 0.3); // A4
    } else if (step === 3) {
      // Hold
      instruction.textContent = "Hold";
      instruction.className = "text-3xl font-semibold text-warning-deep tracking-tight-md";
      
      inner.style.transition = "transform 4000ms linear";
      inner.style.transform = "scale(0.5)";
      
      playChime(392.00, 0.3); // G4
    }
  }

  function startBreathing() {
    initAudio();
    isRunning = true;
    toggleBtn.textContent = "Pause";
    toggleBtn.classList.remove('bg-primary');
    toggleBtn.classList.add('bg-canvas-soft-2', 'border', 'border-hairline', 'text-ink');
    
    step = 0;
    timeLeft = 4;
    updateStepVisuals();
    
    intervalId = setInterval(tick, 1000);
  }

  function stopBreathing() {
    isRunning = false;
    toggleBtn.textContent = "Resume";
    toggleBtn.classList.remove('bg-canvas-soft-2', 'border', 'border-hairline', 'text-ink');
    toggleBtn.classList.add('bg-primary');
    
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = null;
    }
  }

  toggleBtn.addEventListener('click', () => {
    if (isRunning) {
      stopBreathing();
      instruction.textContent = "Paused";
      timer.textContent = "Click resume to continue";
    } else {
      startBreathing();
    }
  });

  // Complete action dispatching
  completeBtn.addEventListener('click', () => {
    const event = new CustomEvent('activityCompleted', { 
      detail: { points: 15, activityName: 'Box Breathing', duration: 2 } 
    });
    window.dispatchEvent(event);
  });

  window.addEventListener('betterthings_tool_reset', () => {
    stopBreathing();
    cyclesCompleted = 0;
    step = 0;
    timeLeft = 4;
    instruction.textContent = "Ready";
    timer.textContent = "4 seconds per step";
    completeBtn.classList.add('hidden');
    toggleBtn.classList.remove('hidden');
    toggleBtn.textContent = "Start";
    cycleCountText.textContent = `Cycle 0 of 4`;
    document.querySelectorAll('[data-dot]').forEach(d => {
      d.classList.add('bg-transparent');
      d.classList.remove('bg-link');
    });
  });
</script>

