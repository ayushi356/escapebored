	// General Stopwatch variables
	let genTimerInterval = null;
	let genSecondsLeft = 0;
	let genTotalSeconds = 0;
	let currentGenActivity = null;

	const genTimerDisplay = document.getElementById('gen-timer-display');
	const genTimerBtn = document.getElementById('gen-timer-btn');
	const genCompleteBtn = document.getElementById('gen-complete-btn');

	function setupGeneralStopwatch(activity) {
		currentGenActivity = activity;
		genTotalSeconds = parseTimeToSeconds(activity.time);
		genSecondsLeft = genTotalSeconds;
		
		document.getElementById('gen-widget-title-bar').textContent = `Task: ${activity.category}`;
		document.getElementById('gen-category').textContent = activity.category;
		document.getElementById('gen-time').textContent = activity.time;
		document.getElementById('gen-title').textContent = activity.title;
		document.getElementById('gen-desc').textContent = activity.description;
		
		clearInterval(genTimerInterval);
		genTimerInterval = null;
		genTimerBtn.textContent = "Start";
		genTimerBtn.className = "h-8 px-4 text-xs rounded-full bg-primary text-on-primary hover:bg-link-deep font-semibold transition-all cursor-pointer";
		
		updateGenDisplay();
	}

	function parseTimeToSeconds(timeStr) {
		const val = parseInt(timeStr);
		if (isNaN(val)) return 300;
		if (timeStr.toLowerCase().includes('second')) {
			return val;
		}
		return val * 60;
	}

	function updateGenDisplay() {
		const mins = Math.floor(genSecondsLeft / 60);
		const secs = genSecondsLeft % 60;
		genTimerDisplay.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
	}

	genTimerBtn.addEventListener('click', () => {
		if (genTimerInterval) {
			clearInterval(genTimerInterval);
			genTimerInterval = null;
			genTimerBtn.textContent = "Resume";
		} else {
			genTimerBtn.textContent = "Pause";
			genTimerInterval = setInterval(() => {
				if (genSecondsLeft > 0) {
					genSecondsLeft--;
					updateGenDisplay();
				} else {
					clearInterval(genTimerInterval);
					genTimerInterval = null;
					genTimerBtn.textContent = "Done!";
					try {
						const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
						const osc = audioCtx.createOscillator();
						const gain = audioCtx.createGain();
						osc.frequency.setValueAtTime(523, audioCtx.currentTime);
						gain.gain.setValueAtTime(0.04, audioCtx.currentTime);
						gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.4);
						osc.connect(gain);
						gain.connect(audioCtx.destination);
						osc.start();
						osc.stop(audioCtx.currentTime + 0.4);
					} catch(e){}
				}
			}, 1000);
		}
	});

	genCompleteBtn.addEventListener('click', () => {
		clearInterval(genTimerInterval);
		genTimerInterval = null;
		toggleWidget('general-widget', false);
		const points = Math.max(5, Math.round(genTotalSeconds / 15));
		window.dispatchEvent(new CustomEvent('activityCompleted', { 
			detail: { 
				points: points, 
				activityName: currentGenActivity.title,
				duration: Math.max(1, Math.round(genTotalSeconds / 60))
			} 
		}));
	});

