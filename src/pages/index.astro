---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

// Tools
import BreathingTool from '../components/tools/BreathingTool.astro';
import FocusTimer from '../components/tools/FocusTimer.astro';
import TypingSprint from '../components/tools/TypingSprint.astro';
import JournalTool from '../components/tools/JournalTool.astro';
import DoodleCanvas from '../components/tools/DoodleCanvas.astro';
import GroundingTool from '../components/tools/GroundingTool.astro';
import StatsDashboard from '../components/StatsDashboard.astro';

import activities from '../data/activities.json';
---

<Layout>
	<!-- Main full screen workspace wrapper -->
	<main id="workspace" class="h-screen w-screen relative overflow-hidden flex select-none">
		<!-- High Quality Background layer -->
		<div id="workspace-bg" class="absolute inset-0 bg-cover bg-center transition-all duration-700 bg-[url('/pixel_lofi_street.jpg')] pointer-events-none z-0"></div>
		
		<!-- Translucent Dark Overlay for premium cozy depth -->
		<div class="absolute inset-0 bg-black/15 pointer-events-none z-0"></div>

		<!-- Mobile Hamburger Toggle -->
		<button id="mobile-sidebar-toggle" class="md:hidden fixed top-4 left-4 w-10 h-10 rounded-xl bg-black/60 backdrop-blur-md border border-white/10 flex items-center justify-center text-white z-50 cursor-pointer hover:bg-black/80 active:scale-95 transition-all shadow-level-2" title="Toggle Sidebar Menu">
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
			</svg>
		</button>

		<!-- Left Fixed Vertical Sidebar -->
		<aside id="sidebar" class="fixed -left-16 md:left-0 top-0 h-full w-16 bg-black/60 backdrop-blur-md border-r border-white/10 z-50 flex flex-col items-center py-6 gap-6 transition-all duration-300">
			<!-- Logo / Return to Onboarding button -->
			<button id="sidebar-home-btn" class="w-10 h-10 rounded-xl bg-white/10 border border-white/20 flex items-center justify-center text-xl select-none cursor-pointer hover:bg-white/20 transition-all" title="Return to Onboarding">
				🕊️
			</button>
			
			<div class="w-8 h-[1px] bg-white/10 my-1"></div>

			<!-- Core Panels (Drawers) toggles -->
			<div class="flex flex-col gap-4">
				<button class="nav-btn group" data-panel="spaces-panel" title="Choose Workspace Theme">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-white/60 group-hover:text-white transition-colors">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
					</svg>
				</button>
				
				<button class="nav-btn group" data-panel="sounds-panel" title="Ambient Sound Controller">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-white/60 group-hover:text-white transition-colors">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 0v11.25m0-11.25L9 12M9 12v6.25m0-6.25L3 14m0 0v5.25m0-5.25L9 18" />
					</svg>
				</button>
				
				<button class="nav-btn group" data-panel="tasks-panel" title="Activity Suggestions Generator">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-white/60 group-hover:text-white transition-colors">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />
						<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" />
					</svg>
				</button>
			</div>

			<div class="w-8 h-[1px] bg-white/10 my-1"></div>

			<!-- Floating Widgets Toggles -->
			<div class="flex flex-col gap-4 flex-1">
				<button class="nav-btn group" data-widget="breathing-widget" title="Box Breathing Exercise">
					<span class="text-sm">🌬️</span>
				</button>
				
				<button class="nav-btn group" data-widget="focustimer-widget" title="Pomodoro Focus Sprint">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-white/60 group-hover:text-white transition-colors">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
				</button>
				
				<button class="nav-btn group" data-widget="journal-widget" title="Reflective Writing Journal">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-white/60 group-hover:text-white transition-colors">
						<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
					</svg>
				</button>
				
				<button class="nav-btn group" data-widget="doodlecanvas-widget" title="Creative Doodle Canvas">
					<span class="text-sm">🎨</span>
				</button>

				<button class="nav-btn group" data-widget="typingsprint-widget" title="Mindful Speed Typing">
					<span class="text-sm">⌨️</span>
				</button>
				
				<button class="nav-btn group" data-widget="stats-widget" title="Progress Stats Dashboard">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-white/60 group-hover:text-white transition-colors">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v5.25c0 .621-.504 1.125-1.125 1.125h-2.25A1.125 1.125 0 013 18.375v-5.25zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125v-9.75zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v14.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
					</svg>
				</button>
			</div>

			<!-- Emergency Panic Trigger at bottom -->
			<button id="sidebar-panic-btn" class="w-10 h-10 rounded-full bg-error hover:bg-error-deep flex items-center justify-center text-white font-bold text-lg cursor-pointer transition-all duration-300 shadow-level-3 hover:shadow-level-5 active:scale-95 z-50 animate-pulse" title="Emergency Panic Grounding">
				🚨
			</button>
		</aside>

		<!-- Left Side Panels Drawer -->
		<div id="side-drawer" class="fixed left-16 top-0 h-full w-[320px] bg-black/80 backdrop-blur-2xl border-r border-white/10 z-40 transform -translate-x-full transition-transform duration-300 cubic-bezier(0.16, 1, 0.3, 1) flex flex-col select-none text-white pt-6 shadow-level-5">
			
			<!-- Spaces Switcher -->
			<div id="spaces-panel" class="drawer-content hidden p-6 flex flex-col h-full gap-4">
				<h3 class="text-xs font-mono text-white/50 uppercase tracking-widest mb-2">Workspace Spaces</h3>
				<div class="flex flex-col gap-4 overflow-y-auto flex-1">
					<div class="space-card cursor-pointer border border-white/20 hover:border-link rounded-lg overflow-hidden transition-all duration-200 group active-space" data-bg="/pixel_lofi_street.jpg">
						<div class="h-28 bg-cover bg-center bg-[url('/pixel_lofi_street.jpg')] group-hover:scale-105 transition-transform duration-500"></div>
						<div class="p-3 bg-white/5 flex justify-between items-center text-xs">
							<span class="font-medium text-white/95">Pixel Cyber City</span>
							<span class="text-[9px] font-mono bg-link px-1.5 py-0.5 rounded text-white uppercase font-bold select-indicator">Active</span>
						</div>
					</div>
					<div class="space-card cursor-pointer border border-white/10 hover:border-link rounded-lg overflow-hidden transition-all duration-200 group" data-bg="/cozy_lofi_space.png">
						<div class="h-28 bg-cover bg-center bg-[url('/cozy_lofi_space.png')] group-hover:scale-105 transition-transform duration-500"></div>
						<div class="p-3 bg-white/5 flex justify-between items-center text-xs">
							<span class="font-medium text-white/95">Cozy Record Cafe</span>
							<span class="text-[9px] font-mono bg-link px-1.5 py-0.5 rounded text-white uppercase font-bold select-indicator hidden">Active</span>
						</div>
					</div>
					<div class="space-card cursor-pointer border border-white/10 hover:border-link rounded-lg overflow-hidden transition-all duration-200 group" data-bg="/rainy_library_space.png">
						<div class="h-28 bg-cover bg-center bg-[url('/rainy_library_space.png')] group-hover:scale-105 transition-transform duration-500"></div>
						<div class="p-3 bg-white/5 flex justify-between items-center text-xs">
							<span class="font-medium text-white/95">Rainy Library</span>
							<span class="text-[9px] font-mono bg-link px-1.5 py-0.5 rounded text-white uppercase font-bold select-indicator hidden">Active</span>
						</div>
					</div>
				</div>
			</div>

			<!-- Sounds Panel -->
			<div id="sounds-panel" class="drawer-content hidden p-6 flex flex-col h-full gap-4">
				<h3 class="text-xs font-mono text-white/50 uppercase tracking-widest mb-1">Ambient Soundscape</h3>
				<p class="text-[10px] text-white/40 mb-2 leading-relaxed">Design your perfect mix of lofi music and custom ambient synthesizers.</p>
				
				<div class="flex flex-col gap-4 overflow-y-auto flex-1 pr-1">
					<!-- Audio Presets Section -->
					<div class="bg-white/5 p-4 rounded-lg border border-white/10 flex flex-col gap-3">
						<span class="text-[9px] font-mono text-white/50 uppercase tracking-wider block border-b border-white/5 pb-1.5">Audio Presets</span>
						<div class="grid grid-cols-2 gap-2">
							<button id="preset-deep-focus" class="preset-audio-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold" data-preset="deep-focus">⚡ Deep Focus</button>
							<button id="preset-rainy-cafe" class="preset-audio-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold" data-preset="rainy-cafe">☕ Rainy Cafe</button>
							<button id="preset-cozy-study" class="preset-audio-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold" data-preset="cozy-study">📚 Cozy Study</button>
							<button id="preset-night-coding" class="preset-audio-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold" data-preset="night-coding">🌙 Night Coding</button>
						</div>
					</div>

					<!-- Audio Player Control -->
					<div class="bg-white/5 p-4 rounded-lg border border-white/10 flex flex-col gap-3">
						<span class="text-[9px] font-mono text-white/50 uppercase tracking-wider block border-b border-white/5 pb-1.5">Lofi Music Player</span>
						
						<!-- Track Selector -->
						<div class="flex flex-col gap-1">
							<span class="text-[9px] font-mono text-white/40 uppercase">Channel</span>
							<select id="lofi-track-select" class="w-full h-8 px-2 text-xs rounded border border-white/10 bg-black/40 text-white font-sans outline-none focus:border-white/20 transition-all">
								<option value="https://stream.laut.fm/lofi">📻 24/7 Lofi Focus Radio</option>
								<option value="https://stream.laut.fm/chilledbeats">🎵 Dreamy Chillout Beats</option>
								<option value="https://stream.laut.fm/chillout-radio">🍵 Lofi Ambient Cafe</option>
								<option value="ambient-only">🔇 Ambient Only (No Music)</option>
							</select>
						</div>

						<div class="flex justify-between items-center mt-1">
							<span class="text-xs font-semibold text-white/90 select-none" id="current-music-label">Lofi Chill Beats</span>
							<button id="lofi-play-btn" class="h-7 px-4 text-[10px] bg-white text-black font-semibold rounded hover:bg-white/90 transition-all cursor-pointer">Play</button>
						</div>
						
						<audio id="lofi-audio" loop src="https://stream.laut.fm/lofi" class="hidden" crossorigin="anonymous"></audio>
						
						<div class="flex items-center gap-2 mt-1">
							<span class="text-[9px] font-mono text-white/50 w-8">VOL</span>
							<input type="range" id="lofi-volume" min="0" max="1" step="0.05" value="0.4" class="w-full h-1 bg-white/10 rounded accent-white cursor-pointer" />
						</div>
					</div>

					<!-- Synthesized Sounds -->
					<div class="bg-white/5 p-4 rounded-lg border border-white/10 flex flex-col gap-4">
						<span class="text-[9px] font-mono text-white/50 uppercase tracking-wider block border-b border-white/5 pb-1.5">Synthesizer & Ambience Mixer</span>
						
						<div class="flex flex-col gap-4">
							<!-- Rain Slider -->
							<div class="flex flex-col gap-1.5">
								<div class="flex items-center justify-between text-xs">
									<span class="text-white/80 flex items-center gap-1.5">
										<input type="checkbox" id="synth-rain-toggle" class="cursor-pointer" />
										🌧️ Soft Rain
									</span>
									<span id="rain-vol-percent" class="text-[10px] font-mono text-white/40">30%</span>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-[9px] font-mono text-white/50 w-8">VOL</span>
									<input type="range" id="synth-rain-volume" min="0" max="1" step="0.05" value="0.3" class="w-full h-1 bg-white/10 rounded accent-white cursor-pointer" />
								</div>
							</div>

							<!-- Ocean Slider -->
							<div class="flex flex-col gap-1.5">
								<div class="flex items-center justify-between text-xs">
									<span class="text-white/80 flex items-center gap-1.5">
										<input type="checkbox" id="synth-ocean-toggle" class="cursor-pointer" />
										🌊 Ocean Swells
									</span>
									<span id="ocean-vol-percent" class="text-[10px] font-mono text-white/40">20%</span>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-[9px] font-mono text-white/50 w-8">VOL</span>
									<input type="range" id="synth-ocean-volume" min="0" max="1" step="0.05" value="0.2" class="w-full h-1 bg-white/10 rounded accent-white cursor-pointer" />
								</div>
							</div>

							<!-- Drone Slider -->
							<div class="flex flex-col gap-1.5">
								<div class="flex items-center justify-between text-xs">
									<span class="text-white/80 flex items-center gap-1.5">
										<input type="checkbox" id="synth-drone-toggle" class="cursor-pointer" />
										🧘 Warm Drone Hum
									</span>
									<span id="drone-vol-percent" class="text-[10px] font-mono text-white/40">20%</span>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-[9px] font-mono text-white/50 w-8">VOL</span>
									<input type="range" id="synth-drone-volume" min="0" max="1" step="0.05" value="0.2" class="w-full h-1 bg-white/10 rounded accent-white cursor-pointer" />
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

				</div>
			</div>

			<!-- Tasks drawer -->
			<div id="tasks-panel" class="drawer-content hidden p-6 flex flex-col h-full gap-4">
				<h3 class="text-xs font-mono text-white/50 uppercase tracking-widest mb-1">Focus Task Explorer</h3>
				<p class="text-[10px] text-white/40 mb-2 leading-relaxed">Filter and click an activity below to spawn its focus widget card instantly.</p>
				
				<!-- Filters -->
				<div class="grid grid-cols-2 gap-2 mb-2">
					<button class="task-filter-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold active-filter" data-filter="any">Show All</button>
					<button class="task-filter-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold" data-filter="quick">Under 3 Min</button>
					<button class="task-filter-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold" data-filter="Learning">Learn Concept</button>
					<button class="task-filter-btn text-[10px] border border-white/10 bg-white/5 py-1.5 rounded hover:bg-white/10 transition-all font-semibold" data-filter="procrastinating">Break Stall</button>
				</div>

				<!-- Suggested list container -->
				<div id="drawer-activities-list" class="flex-1 overflow-y-auto flex flex-col gap-2 pr-1">
					<!-- Injected dynamically in script -->
				</div>
			</div>

		</div>

		<!-- MAIN CENTRAL ONBOARDING FLOW -->
		<div id="onboarding-flow" class="absolute inset-0 flex items-center justify-center pointer-events-none z-20 overflow-y-auto py-8 px-4 transition-all duration-300 transform scale-100 opacity-100">
			<div class="w-full max-w-lg bg-black/60 backdrop-blur-2xl border border-white/10 rounded-2xl p-8 shadow-level-5 flex flex-col gap-6 pointer-events-auto transition-all duration-500 max-h-[90vh] overflow-y-auto text-center text-white relative">
				
				<!-- Onboarding Skip/Dashboard button -->
				<button id="onboarding-skip-btn" class="absolute top-4 right-4 text-xs font-mono text-white/50 hover:text-white transition-colors cursor-pointer" title="Go to Dashboard">Skip to Dashboard →</button>

				<!-- STEP 0: Welcome / Value Proposition -->
				<div id="onboarding-step-welcome" class="flex flex-col gap-6 py-4">
					<div class="flex flex-col items-center gap-2">
						<div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-3xl shadow-level-2 select-none">
							🕊️
						</div>
						<h1 class="text-4xl font-bold tracking-tight-xl text-white mt-2">EscapeBored</h1>
						<p class="text-xs text-white/55 uppercase font-mono tracking-widest">Trade scrolling for mindful actions</p>
					</div>

					<p class="text-sm text-white/85 max-w-sm mx-auto leading-relaxed">
						Trade doomscrolling and digital fatigue for instant, micro-mindful moments that secure your focus and calm your mind.
					</p>

					<div class="py-2">
						<button id="welcome-start-btn" class="w-full h-12 bg-white text-black hover:bg-white/95 font-semibold rounded-xl text-sm transition-all duration-300 shadow-level-3 active:scale-98 cursor-pointer animate-pulse">
							I'm Bored — Give Me Something To Do
						</button>
					</div>

					<!-- Quick stats footer inside card -->
					<div class="flex items-center justify-around bg-white/5 border border-white/5 rounded-xl p-3 text-xs mt-2">
						<div class="flex flex-col items-center gap-0.5">
							<span class="text-[10px] font-mono text-white/40 uppercase">Time Saved</span>
							<span id="onboarding-stat-saved" class="font-semibold text-white">0 min</span>
						</div>
						<div class="w-[1px] h-6 bg-white/10"></div>
						<div class="flex flex-col items-center gap-0.5">
							<span class="text-[10px] font-mono text-white/40 uppercase">Streak</span>
							<span id="onboarding-stat-streak" class="font-semibold text-white">0 Days</span>
						</div>
						<div class="w-[1px] h-6 bg-white/10"></div>
						<div class="flex flex-col items-center gap-0.5">
							<span class="text-[10px] font-mono text-white/40 uppercase">Daily CP</span>
							<span id="onboarding-stat-cp" class="font-semibold text-link">0/50</span>
						</div>
					</div>
				</div>

				<!-- STEP 1: Mood Selection -->
				<div id="onboarding-step-mood" class="hidden flex flex-col gap-6 py-2">
					<div class="flex flex-col gap-1">
						<h2 class="text-2xl font-bold text-white tracking-tight-lg">How are you feeling?</h2>
						<p class="text-xs text-white/50">We'll tailor an activity to your current energy level.</p>
					</div>
					
					<div class="grid grid-cols-1 gap-3 max-h-[45vh] overflow-y-auto pr-1">
						<button class="mood-btn" data-mood="Bored">
							<span class="text-xl text-left flex-shrink-0">🥱</span>
							<div class="text-left">
								<div class="font-semibold text-sm text-white">Bored</div>
								<div class="text-[10px] text-white/50 leading-tight mt-0.5">Looking for a quick curiosity spark or small concept</div>
							</div>
						</button>
						<button class="mood-btn" data-mood="Stressed">
							<span class="text-xl text-left flex-shrink-0">😰</span>
							<div class="text-left">
								<div class="font-semibold text-sm text-white">Stressed</div>
								<div class="text-[10px] text-white/50 leading-tight mt-0.5">Need a calming breathing routine or quick grounding</div>
							</div>
						</button>
						<button class="mood-btn" data-mood="Restless">
							<span class="text-xl text-left flex-shrink-0">🌀</span>
							<div class="text-left">
								<div class="font-semibold text-sm text-white">Restless</div>
								<div class="text-[10px] text-white/50 leading-tight mt-0.5">High physical energy, need movement or speed typing</div>
							</div>
						</button>
						<button class="mood-btn" data-mood="Curious">
							<span class="text-xl text-left flex-shrink-0">💡</span>
							<div class="text-left">
								<div class="font-semibold text-sm text-white">Curious</div>
								<div class="text-[10px] text-white/50 leading-tight mt-0.5">Want to learn something cool or solve a quick puzzle</div>
							</div>
						</button>
