	function loadOnboardingStats() {
		const points = parseInt(localStorage.getItem('betterthings_points') || '0');
		const streak = parseInt(localStorage.getItem('betterthings_streak') || '0');
		const minutesSaved = parseInt(localStorage.getItem('escapebored_minutes_saved') || '0');

		const statSaved = document.getElementById('onboarding-stat-saved');
		const statStreak = document.getElementById('onboarding-stat-streak');
		const statCp = document.getElementById('onboarding-stat-cp');

		if (statSaved) statSaved.textContent = `${minutesSaved} min`;
		if (statStreak) statStreak.textContent = `${streak} ${streak === 1 ? 'Day' : 'Days'}`;
		if (statCp) statCp.textContent = `${points}/50 CP`;
	}

	function generateRecommendation() {
		const list = activities.filter(activity => {
			const seconds = parseTimeToSeconds(activity.time);
			return seconds <= currentTimeLimit;
		});

		let moodFiltered = list.filter(activity => {
			return activity.moods && activity.moods.includes(currentMood);
		});
		
		if (moodFiltered.length === 0) moodFiltered = list.length > 0 ? list : activities;

		matchingActivities = moodFiltered;
		shuffleRecommendation();
	}

	function shuffleRecommendation() {
		if (matchingActivities.length > 0) {
			const idx = Math.floor(Math.random() * matchingActivities.length);
			selectedActivity = matchingActivities[idx];
			
			document.getElementById('recommend-title').textContent = selectedActivity.title;
			document.getElementById('recommend-desc').textContent = selectedActivity.description;
			document.getElementById('recommend-category').textContent = selectedActivity.category;
			document.getElementById('recommend-time').textContent = selectedActivity.time;
		}
	}

	function transitionStep(fromId, toId) {
		const fromEl = document.getElementById(fromId);
		const toEl = document.getElementById(toId);
		if (fromEl && toEl) {
			fromEl.classList.add('hidden');
			toEl.classList.remove('hidden');
		}
	}

	// Home Button Listener (Returns to onboarding)
	const homeBtn = document.getElementById('nav-home-btn');
	if (homeBtn) {
		homeBtn.addEventListener('click', () => {
			closeAllPopovers();
			showOnboardingFlow(true);
		});
	}

	// Onboarding Welcome Start
	const welcomeStartBtn = document.getElementById('welcome-start-btn');
	if (welcomeStartBtn) {
		welcomeStartBtn.addEventListener('click', () => {
			transitionStep('onboarding-step-welcome', 'onboarding-step-mood');
		});
	}

	// Mood Selector
	const moodBtns = document.querySelectorAll('.mood-btn-cozy');
	moodBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			currentMood = btn.getAttribute('data-mood');
			transitionStep('onboarding-step-mood', 'onboarding-step-time');
		});
	});

	// Time Selector
	const timeBtns = document.querySelectorAll('.time-btn-cozy');
	timeBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			currentTimeLimit = parseInt(btn.getAttribute('data-time'));
			generateRecommendation();
			transitionStep('onboarding-step-time', 'onboarding-step-recommend');
		});
	});

	// Back Buttons
	const backBtns = document.querySelectorAll('.onboarding-back-btn');
	backBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const target = btn.getAttribute('data-to');
			if (target === 'mood') {
				transitionStep('onboarding-step-time', 'onboarding-step-mood');
			} else if (target === 'time') {
				transitionStep('onboarding-step-recommend', 'onboarding-step-time');
			}
		});
	});

	// Onboarding Shuffle
	const shuffleBtn = document.getElementById('recommend-shuffle-btn');
	if (shuffleBtn) {
		shuffleBtn.addEventListener('click', () => {
			shuffleRecommendation();
		});
	}

	// Onboarding Accept Recommendation
	const recommendAcceptBtn = document.getElementById('recommend-accept-btn');
	if (recommendAcceptBtn) {
		recommendAcceptBtn.addEventListener('click', () => {
			if (selectedActivity) {
				showOnboardingFlow(false);
				launchTaskWidget(selectedActivity);
			}
		});
	}

	// Skip Onboarding
	const skipBtn = document.getElementById('onboarding-skip-btn');
	if (skipBtn) {
		skipBtn.addEventListener('click', () => {
			showOnboardingFlow(false);
			showDashboardHub(true);
		});
	}

	// Tool Cards Listener inside Hub
	const hubToolCards = document.querySelectorAll('.hub-tool-card-cozy');
	hubToolCards.forEach(card => {
		card.addEventListener('click', () => {
			const widgetId = card.getAttribute('data-widget-toggle');
			if (widgetId) {
				toggleWidget(widgetId, true);
			}
		});
	});

	// Register completion and refresh event listeners
	window.addEventListener('betterthings_refresh_view', () => {
		loadHubStats();
		loadOnboardingStats();
	});

	// Initial render & stats load
	renderDrawerTasks(currentTaskFilter);
	loadHubStats();
	loadOnboardingStats();
</script>

