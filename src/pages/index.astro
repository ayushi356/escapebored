						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
					</svg>
				</div>
				<h2 class="text-4xl md:text-5xl font-semibold tracking-tight-lg mb-2 text-white">Well done.</h2>
				<p id="done-points-earned" class="text-link font-mono font-semibold text-xl mb-1">+15 Clarity Points</p>
				<p id="done-activity-name" class="text-white/40 text-xs font-mono uppercase mb-6">Completed: Box Breathing</p>
				<p class="text-white/80 text-sm mb-8 max-w-sm leading-relaxed">You just traded doomscrolling for a focused moment of self-growth.</p>
				<Button id="finish-reset" variant="primary" class="!px-8 !h-10 !text-xs">Continue Focus</Button>
			</div>
		</div>

	</main>
</Layout>

<script define:vars={{ activities }}>
	// 1. Draggable Widget Script
	function makeDraggable(element) {
		let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
		const header = element.querySelector('.widget-header');
		
		if (header) {
			header.onmousedown = dragMouseDown;
			header.ontouchstart = dragMouseDown;
		}

		function dragMouseDown(e) {
			e = e || window.event;
			// Don't drag if clicking buttons inside the header
			if (e.target.closest('.header-actions') || e.target.tagName === 'BUTTON') return;
			
			// Bring clicked widget to front
			bringToFront(element);

			const clientX = e.touches ? e.touches[0].clientX : e.clientX;
			const clientY = e.touches ? e.touches[0].clientY : e.clientY;
			
			pos3 = clientX;
			pos4 = clientY;
			
			document.onmouseup = closeDragElement;
			document.onmousemove = elementDrag;
			document.ontouchend = closeDragElement;
			document.ontouchmove = elementDrag;
		}

		function elementDrag(e) {
			e = e || window.event;
			const clientX = e.touches ? e.touches[0].clientX : e.clientX;
			const clientY = e.touches ? e.touches[0].clientY : e.clientY;
			
			pos1 = pos3 - clientX;
			pos2 = pos4 - clientY;
			pos3 = clientX;
			pos4 = clientY;
			
			// Compute boundaries to keep widgets on screen slightly
			const newTop = element.offsetTop - pos2;
			const newLeft = element.offsetLeft - pos1;

			element.style.top = Math.max(10, Math.min(newTop, window.innerHeight - 100)) + "px";
			element.style.left = Math.max(10, Math.min(newLeft, window.innerWidth - 100)) + "px";
			element.style.right = 'auto';
			element.style.bottom = 'auto';
		}

		function closeDragElement() {
			document.onmouseup = null;
			document.onmousemove = null;
			document.ontouchend = null;
			document.ontouchmove = null;
		}
	}

	let currentZIndex = 30;
	function bringToFront(element) {
		currentZIndex++;
		element.style.zIndex = currentZIndex.toString();
	}

	// Setup draggability on all widgets
	const widgets = document.querySelectorAll('.draggable-widget');
	widgets.forEach(widget => {
		makeDraggable(widget);
		
		// Setup minimizing listeners
		const minBtn = widget.querySelector('.widget-minimize-btn');
		const body = widget.querySelector('.widget-body');
		if (minBtn && body) {
			minBtn.addEventListener('click', () => {
				body.classList.toggle('hidden');
				widget.classList.toggle('w-fit');
			});
		}

		// Setup closing listeners
		const closeBtn = widget.querySelector('.widget-close-btn');
		if (closeBtn) {
			closeBtn.addEventListener('click', () => {
				toggleWidget(widget.id, false);
				// Dispatch reset inside sub-tools
				window.dispatchEvent(new CustomEvent('betterthings_tool_reset'));
			});
		}
	});

	// Toggle widget visibility
	function toggleWidget(id, show = true) {
		const widget = document.getElementById(id);
		if (widget) {
			if (show) {
				widget.classList.remove('hidden');
				bringToFront(widget);
				showDashboardHub(false);
				showOnboardingFlow(false);
			} else {
				widget.classList.add('hidden');
				// Check if any other widgets are still open
				const anyOpen = Array.from(widgets).some(w => !w.classList.contains('hidden') && w.id !== 'grounding-widget');
				if (!anyOpen) {
					showDashboardHub(true);
				}
			}
		}
	}

	// 2. Sidebar Navigation Control
	const navBtns = document.querySelectorAll('.nav-btn');
	const sideDrawer = document.getElementById('side-drawer');
	const drawerContents = document.querySelectorAll('.drawer-content');
	let activePanel = null;

	navBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const panelId = btn.getAttribute('data-panel');
			const widgetId = btn.getAttribute('data-widget');

			if (panelId) {
				// Manage Drawers
				if (activePanel === panelId) {
					// Close drawer
					sideDrawer.classList.add('-translate-x-full');
					activePanel = null;
				} else {
					// Open drawer & show correct panel
					drawerContents.forEach(c => c.classList.add('hidden'));
					document.getElementById(panelId).classList.remove('hidden');
					sideDrawer.classList.remove('-translate-x-full');
					activePanel = panelId;
				}
			} else if (widgetId) {
				// Manage Widgets
				const widget = document.getElementById(widgetId);
				const isHidden = widget.classList.contains('hidden');
				toggleWidget(widgetId, isHidden);
			}
		});
	});

	// Close drawer if clicking background workspace
	document.getElementById('workspace').addEventListener('click', (e) => {
		if (e.target === document.getElementById('workspace')) {
			sideDrawer.classList.add('-translate-x-full');
			activePanel = null;
		}
	});

	// Emergency Panic Action
	document.getElementById('sidebar-panic-btn').addEventListener('click', () => {
		toggleWidget('grounding-widget', true);
		// Center grounding widget
		const widget = document.getElementById('grounding-widget');
		widget.style.top = '15%';
		widget.style.left = '30%';
		sideDrawer.classList.add('-translate-x-full');
		activePanel = null;
	});

	// 3. Dynamic background switching
	const spaceCards = document.querySelectorAll('.space-card');
	spaceCards.forEach(card => {
		card.addEventListener('click', () => {
			spaceCards.forEach(c => {
				c.classList.remove('border-link', 'active-space');
				c.classList.add('border-white/10');
				c.querySelector('.select-indicator').classList.add('hidden');
			});
			card.classList.add('border-link', 'active-space');
			card.classList.remove('border-white/10');
			card.querySelector('.select-indicator').classList.remove('hidden');
			
			const bg = card.getAttribute('data-bg');
			document.getElementById('workspace-bg').style.backgroundImage = `url('${bg}')`;
		});
	});

	// 4. Sound panel music and global audio synthesizers
	const playBtn = document.getElementById('lofi-play-btn');
	const audioEl = document.getElementById('lofi-audio');
	const volInput = document.getElementById('lofi-volume');
	const lofiTrackSelect = document.getElementById('lofi-track-select');
	const currentMusicLabel = document.getElementById('current-music-label');

	let audioFadeInterval = null;

	function fadeInAudio(audioElement, targetVolume, duration = 1500) {
		clearInterval(audioFadeInterval);
		audioElement.volume = 0;
		return audioElement.play().then(() => {
			const start = Date.now();
			audioFadeInterval = setInterval(() => {
				const elapsed = Date.now() - start;
				const progress = Math.min(elapsed / duration, 1);
				audioElement.volume = progress * targetVolume;
				if (progress >= 1) {
					clearInterval(audioFadeInterval);
				}
			}, 30);
		}).catch(err => console.log("Audio play interrupted/blocked:", err));
	}

	function fadeOutAudio(audioElement, duration = 1000) {
		clearInterval(audioFadeInterval);
		const start = Date.now();
		const initialVol = audioElement.volume;
		audioFadeInterval = setInterval(() => {
			const elapsed = Date.now() - start;
			const progress = Math.min(elapsed / duration, 1);
			audioElement.volume = initialVol * (1 - progress);
			if (progress >= 1) {
				clearInterval(audioFadeInterval);
				audioElement.pause();
				audioElement.volume = initialVol;
			}
		}, 30);
	}

	playBtn.addEventListener('click', () => {
		if (audioEl.paused) {
			fadeInAudio(audioEl, parseFloat(volInput.value)).then(() => {
				playBtn.textContent = 'Pause';
				playBtn.classList.add('bg-link', 'text-white');
			});
		} else {
			fadeOutAudio(audioEl);
			playBtn.textContent = 'Play';
			playBtn.classList.remove('bg-link', 'text-white');
		}
	});

	volInput.addEventListener('input', () => {
		if (!audioEl.paused) {
			audioEl.volume = parseFloat(volInput.value);
		}
	});

	lofiTrackSelect.addEventListener('change', () => {
		const selectedUrl = lofiTrackSelect.value;
		const selectedText = lofiTrackSelect.options[lofiTrackSelect.selectedIndex].text;
		currentMusicLabel.textContent = selectedText.split(' ').slice(1).join(' '); // remove emoji

		if (selectedUrl === 'ambient-only') {
			if (!audioEl.paused) {
				fadeOutAudio(audioEl);
				playBtn.textContent = 'Play';
				playBtn.classList.remove('bg-link', 'text-white');
			}
			playBtn.disabled = true;
			playBtn.classList.add('opacity-30', 'pointer-events-none');
		} else {
			playBtn.disabled = false;
			playBtn.classList.remove('opacity-30', 'pointer-events-none');
			const wasPlaying = !audioEl.paused;
			audioEl.src = selectedUrl;
			if (wasPlaying) {
				fadeInAudio(audioEl, parseFloat(volInput.value));
			}
		}
	});

	// Global synthesizers
	let synthCtx = null;
	let rainNode = null;
	let rainGain = null;
	let wavesNode = null;
	let wavesGain = null;
	let wavesModulator = null;
	let droneOscillators = [];
	let droneGain = null;

	let rainVol = 0.3;
	let oceanVol = 0.2;
	let droneVol = 0.2;

	function initSynthCtx() {
		if (!synthCtx) {
			synthCtx = new (window.AudioContext || window.webkitAudioContext)();
		}
		if (synthCtx.state === 'suspended') {
			synthCtx.resume();
		}
	}

	function createNoiseBuffer() {
		const size = synthCtx.sampleRate * 2;
		const buffer = synthCtx.createBuffer(1, size, synthCtx.sampleRate);
		const output = buffer.getChannelData(0);
		for (let i = 0; i < size; i++) {
			output[i] = Math.random() * 2 - 1;
		}
		return buffer;
	}

	// Rain
	function startRain() {
		initSynthCtx();
		if (rainNode) return;
		const buffer = createNoiseBuffer();
		rainNode = synthCtx.createBufferSource();
		rainNode.buffer = buffer;
		rainNode.loop = true;

		const filter = synthCtx.createBiquadFilter();
		filter.type = 'lowpass';
		filter.frequency.setValueAtTime(500, synthCtx.currentTime);

		const filter2 = synthCtx.createBiquadFilter();
		filter2.type = 'bandpass';
		filter2.frequency.setValueAtTime(800, synthCtx.currentTime);
		filter2.Q.setValueAtTime(0.8, synthCtx.currentTime);

		rainGain = synthCtx.createGain();
		rainGain.gain.setValueAtTime(0, synthCtx.currentTime);
		rainGain.gain.linearRampToValueAtTime(rainVol, synthCtx.currentTime + 1.5);

		rainNode.connect(filter);
		filter.connect(filter2);
		filter2.connect(rainGain);
		rainGain.connect(synthCtx.destination);
		rainNode.start(0);
	}

	function stopRain() {
		if (rainNode && rainGain) {
			const nodeToStop = rainNode;
			const gainToFade = rainGain;
			rainNode = null;
			rainGain = null;

			gainToFade.gain.setValueAtTime(gainToFade.gain.value, synthCtx.currentTime);
			gainToFade.gain.linearRampToValueAtTime(0, synthCtx.currentTime + 1.0);
			setTimeout(() => {
				try { nodeToStop.stop(); } catch(e){}
				nodeToStop.disconnect();
				gainToFade.disconnect();
			}, 1000);
		}
	}

	// Waves
	function startWaves() {
		initSynthCtx();
		if (wavesNode) return;
		const buffer = createNoiseBuffer();
		wavesNode = synthCtx.createBufferSource();
		wavesNode.buffer = buffer;
		wavesNode.loop = true;

		const filter = synthCtx.createBiquadFilter();
		filter.type = 'lowpass';
		filter.frequency.setValueAtTime(250, synthCtx.currentTime);

		wavesGain = synthCtx.createGain();
		wavesGain.gain.setValueAtTime(0, synthCtx.currentTime);
		wavesGain.gain.linearRampToValueAtTime(oceanVol, synthCtx.currentTime + 2.0);

		wavesModulator = synthCtx.createOscillator();
		wavesModulator.frequency.setValueAtTime(0.08, synthCtx.currentTime);
		const modGain = synthCtx.createGain();
		modGain.gain.setValueAtTime(150, synthCtx.currentTime);

		wavesModulator.connect(modGain);
		modGain.connect(filter.frequency);

		const panner = synthCtx.createStereoPanner ? synthCtx.createStereoPanner() : null;
		if (panner) {
			const panLfo = synthCtx.createOscillator();
			panLfo.frequency.setValueAtTime(0.05, synthCtx.currentTime);
			const panGain = synthCtx.createGain();
			panGain.gain.setValueAtTime(0.6, synthCtx.currentTime);
			
			panLfo.connect(panGain);
			panGain.connect(panner.pan);
			panLfo.start(0);
			
			wavesNode.connect(filter);
			filter.connect(wavesGain);
			wavesGain.connect(panner);
			panner.connect(synthCtx.destination);
			
			wavesNode.panLfo = panLfo;
			wavesNode.panner = panner;
		} else {
			wavesNode.connect(filter);
			filter.connect(wavesGain);
			wavesGain.connect(synthCtx.destination);
		}

		wavesModulator.start(0);
		wavesNode.start(0);
	}

	function stopWaves() {
		if (wavesNode && wavesGain) {
			const nodeToStop = wavesNode;
			const modulatorToStop = wavesModulator;
			const gainToFade = wavesGain;
			
			wavesNode = null;
			wavesModulator = null;
			wavesGain = null;

			gainToFade.gain.setValueAtTime(gainToFade.gain.value, synthCtx.currentTime);
			gainToFade.gain.linearRampToValueAtTime(0, synthCtx.currentTime + 1.2);
			
			setTimeout(() => {
				try { nodeToStop.stop(); } catch(e){}
				try { modulatorToStop.stop(); } catch(e){}
				if (nodeToStop.panLfo) {
					try { nodeToStop.panLfo.stop(); } catch(e){}
					nodeToStop.panLfo.disconnect();
				}
				if (nodeToStop.panner) {
					nodeToStop.panner.disconnect();
				}
				nodeToStop.disconnect();
				modulatorToStop.disconnect();
				gainToFade.disconnect();
			}, 1200);
		}
	}

	// Drone chord hum
	function startDrone() {
		initSynthCtx();
		if (droneOscillators.length > 0) return;
		const frequencies = [130.81, 196.00, 261.63, 329.63]; // C3, G3, C4, E4
		
		droneGain = synthCtx.createGain();
		droneGain.gain.setValueAtTime(0, synthCtx.currentTime);
		droneGain.gain.linearRampToValueAtTime(droneVol, synthCtx.currentTime + 2.0);

		const oscillators = frequencies.map((freq, idx) => {
			const osc = synthCtx.createOscillator();
			osc.type = 'sine';
			osc.frequency.setValueAtTime(freq + (Math.random() - 0.5) * 0.6, synthCtx.currentTime);
			
			const trem = synthCtx.createOscillator();
			trem.frequency.setValueAtTime(0.20 + idx * 0.05, synthCtx.currentTime);
			const tremGain = synthCtx.createGain();
			tremGain.gain.setValueAtTime(0.03, synthCtx.currentTime);
			
			const oscGain = synthCtx.createGain();
			oscGain.gain.setValueAtTime(0.22, synthCtx.currentTime);
			
			trem.connect(tremGain);
			tremGain.connect(oscGain.gain);
			
			osc.connect(oscGain);
			oscGain.connect(droneGain);
			
			trem.start(0);
			osc.start(0);
			
			return { osc, trem };
		});

		const subOsc = synthCtx.createOscillator();
		subOsc.type = 'triangle';
		subOsc.frequency.setValueAtTime(65.41, synthCtx.currentTime);
		const subGain = synthCtx.createGain();
		subGain.gain.setValueAtTime(0.15, synthCtx.currentTime);
		subOsc.connect(subGain);
		subGain.connect(droneGain);
		subOsc.start(0);

		const filter = synthCtx.createBiquadFilter();
		filter.type = 'lowpass';
		filter.frequency.setValueAtTime(280, synthCtx.currentTime);

		droneGain.connect(filter);
		filter.connect(synthCtx.destination);

		droneOscillators = [...oscillators, { osc: subOsc, trem: null }];
	}

	function stopDrone() {
		if (droneOscillators.length > 0 && droneGain) {
			const oscsToStop = droneOscillators;
			const gainToFade = droneGain;
			
			droneOscillators = [];
			droneGain = null;

			gainToFade.gain.setValueAtTime(gainToFade.gain.value, synthCtx.currentTime);
			gainToFade.gain.linearRampToValueAtTime(0, synthCtx.currentTime + 1.5);

			setTimeout(() => {
				oscsToStop.forEach(({ osc, trem }) => {
					try { osc.stop(); } catch(e){}
					osc.disconnect();
					if (trem) {
						try { trem.stop(); } catch(e){}
						trem.disconnect();
					}
				});
				gainToFade.disconnect();
			}, 1500);
		}
	}

	// Synthesizer Event Listeners
	document.getElementById('synth-rain-toggle').addEventListener('change', (e) => {
		const target = e.target;
		if (target.checked) startRain();
		else stopRain();
	});

	document.getElementById('synth-ocean-toggle').addEventListener('change', (e) => {
		const target = e.target;
		if (target.checked) startWaves();
		else stopWaves();
	});

	document.getElementById('synth-drone-toggle').addEventListener('change', (e) => {
		const target = e.target;
		if (target.checked) startDrone();
		else stopDrone();
	});

	const rainVolSlider = document.getElementById('synth-rain-volume');
	const oceanVolSlider = document.getElementById('synth-ocean-volume');
	const droneVolSlider = document.getElementById('synth-drone-volume');

	const rainVolPercent = document.getElementById('rain-vol-percent');
	const oceanVolPercent = document.getElementById('ocean-vol-percent');
	const droneVolPercent = document.getElementById('drone-vol-percent');

	rainVolSlider.addEventListener('input', () => {
		rainVol = parseFloat(rainVolSlider.value);
		rainVolPercent.textContent = `${Math.round(rainVol * 100)}%`;
		if (rainGain) {
			rainGain.gain.setValueAtTime(rainVol, synthCtx.currentTime);
		}
	});

	oceanVolSlider.addEventListener('input', () => {
		oceanVol = parseFloat(oceanVolSlider.value);
		oceanVolPercent.textContent = `${Math.round(oceanVol * 100)}%`;
		if (wavesGain) {
			wavesGain.gain.setValueAtTime(oceanVol, synthCtx.currentTime);
		}
	});

	droneVolSlider.addEventListener('input', () => {
		droneVol = parseFloat(droneVolSlider.value);
		droneVolPercent.textContent = `${Math.round(droneVol * 100)}%`;
		if (droneGain) {
			droneGain.gain.setValueAtTime(droneVol, synthCtx.currentTime);
		}
	});

	// Preset management
	const presetBtns = document.querySelectorAll('.preset-audio-btn');

	function selectPreset(presetName) {
		presetBtns.forEach(btn => {
			if (btn.getAttribute('data-preset') === presetName) {
				btn.classList.add('bg-link', 'text-white', 'border-link');
				btn.classList.remove('bg-white/5', 'border-white/10');
			} else {
				btn.classList.remove('bg-link', 'text-white', 'border-link');
				btn.classList.add('bg-white/5', 'border-white/10');
			}
		});

		let config = {
			track: 'https://stream.laut.fm/lofi',
			musicPlay: true,
			musicVol: 0.3,
			rainOn: false,
			rainVolVal: 0.3,
			oceanOn: false,
			oceanVolVal: 0.2,
			droneOn: false,
			droneVolVal: 0.2
		};

		if (presetName === 'deep-focus') {
			config.track = 'ambient-only';
			config.musicPlay = false;
			config.droneOn = true;
			config.droneVolVal = 0.45;
		} else if (presetName === 'rainy-cafe') {
			config.track = 'https://stream.laut.fm/chillout-radio';
			config.musicPlay = true;
			config.musicVol = 0.4;
			config.rainOn = true;
			config.rainVolVal = 0.6;
		} else if (presetName === 'cozy-study') {
			config.track = 'https://stream.laut.fm/chilledbeats';
			config.musicPlay = true;
			config.musicVol = 0.35;
			config.rainOn = true;
			config.rainVolVal = 0.25;
			config.oceanOn = true;
			config.oceanVolVal = 0.15;
		} else if (presetName === 'night-coding') {
			config.track = 'https://stream.laut.fm/lofi';
			config.musicPlay = true;
			config.musicVol = 0.3;
			config.droneOn = true;
			config.droneVolVal = 0.4;
		}

		lofiTrackSelect.value = config.track;
		const changeEvent = new Event('change');
		lofiTrackSelect.dispatchEvent(changeEvent);

		volInput.value = config.musicVol.toString();
		
		if (config.musicPlay) {
			fadeInAudio(audioEl, config.musicVol).then(() => {
				playBtn.textContent = 'Pause';
				playBtn.classList.add('bg-link', 'text-white');
			});
		} else {
			fadeOutAudio(audioEl);
			playBtn.textContent = 'Play';
			playBtn.classList.remove('bg-link', 'text-white');
		}

		// Rain
		const rainCheck = document.getElementById('synth-rain-toggle');
		rainVol = config.rainVolVal;
		rainVolSlider.value = rainVol.toString();
		rainVolPercent.textContent = `${Math.round(rainVol * 100)}%`;
		if (config.rainOn) {
			rainCheck.checked = true;
			startRain();
		} else {
			rainCheck.checked = false;
			stopRain();
		}

		// Ocean
		const oceanCheck = document.getElementById('synth-ocean-toggle');
		oceanVol = config.oceanVolVal;
		oceanVolSlider.value = oceanVol.toString();
		oceanVolPercent.textContent = `${Math.round(oceanVol * 100)}%`;
		if (config.oceanOn) {
			oceanCheck.checked = true;
			startWaves();
		} else {
			oceanCheck.checked = false;
			stopWaves();
		}

		// Drone
		const droneCheck = document.getElementById('synth-drone-toggle');
		droneVol = config.droneVolVal;
		droneVolSlider.value = droneVol.toString();
		droneVolPercent.textContent = `${Math.round(droneVol * 100)}%`;
		if (config.droneOn) {
			droneCheck.checked = true;
			startDrone();
		} else {
			droneCheck.checked = false;
			stopDrone();
		}
	}

	// 5. Tasks drawer recommendations list builder
	const activitiesListContainer = document.getElementById('drawer-activities-list');
	const filterButtons = document.querySelectorAll('.task-filter-btn');
	let currentTaskFilter = 'any';

	function getFilteredActivities(filter) {
		if (filter === 'quick') {
			return activities.filter(a => parseInt(a.time) <= 3);
		} else if (filter === 'procrastinating') {
			return activities.filter(a => ['Productivity', 'Reflection', 'Wellness'].includes(a.category));
		} else if (filter === 'Learning') {
			return activities.filter(a => a.category === 'Learning');
		}
		return activities;
	}

	function renderDrawerTasks(filter) {
		const list = getFilteredActivities(filter);
		activitiesListContainer.innerHTML = '';
		
		// Render 8 shuffled tasks to keep the vault dynamic
		const shuffled = [...list].sort(() => 0.5 - Math.random()).slice(0, 10);
		
		shuffled.forEach(task => {
			const item = document.createElement('div');
			item.className = "p-3 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 hover:border-white/20 transition-all duration-200 cursor-pointer flex flex-col gap-1 text-left";
			item.innerHTML = `
				<div class="flex justify-between items-center">
					<span class="text-[8px] font-mono text-white/50 uppercase tracking-wider">${task.category}</span>
					<span class="text-[8px] font-mono text-white/50 uppercase tracking-wider">${task.time}</span>
				</div>
				<h4 class="text-xs font-semibold text-white/90 leading-snug">${task.title}</h4>
			`;
			item.addEventListener('click', () => {
				launchTaskWidget(task);
			});
			activitiesListContainer.appendChild(item);
		});
	}

	filterButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			filterButtons.forEach(b => b.classList.remove('active-filter'));
			btn.classList.add('active-filter');
			currentTaskFilter = btn.getAttribute('data-filter');
			renderDrawerTasks(currentTaskFilter);
		});
	});

	// General Stopwatch widget variables
	let genTimerInterval = null;
	let genSecondsLeft = 0;
	let genTotalSeconds = 0;
	let currentGenActivity = null;

	const genTimerDisplay = document.getElementById('gen-timer-display');
	const genTimerBtn = document.getElementById('gen-timer-btn');
	const genCompleteBtn = document.getElementById('gen-complete-btn');

	function setupGeneralStopwatch(activity) {
		currentGenActivity = activity;
		genTotalSeconds = parseTimeToSeconds(activity.time);
		genSecondsLeft = genTotalSeconds;
		
		document.getElementById('gen-widget-title-bar').textContent = `Task: ${activity.category}`;
		document.getElementById('gen-category').textContent = activity.category;
		document.getElementById('gen-time').textContent = activity.time;
		document.getElementById('gen-title').textContent = activity.title;
		document.getElementById('gen-desc').textContent = activity.description;
		
		clearInterval(genTimerInterval);
		genTimerInterval = null;
		genTimerBtn.textContent = "Start";
		genTimerBtn.className = "h-8 px-4 text-xs rounded-pill bg-white text-black hover:bg-white/90 font-medium transition-all cursor-pointer";
		
		updateGenDisplay();
	}

	function parseTimeToSeconds(timeStr) {
		const val = parseInt(timeStr);
		if (isNaN(val)) return 300;
		if (timeStr.toLowerCase().includes('second')) {
			return val;
		}
		return val * 60;
	}

	function updateGenDisplay() {
		const mins = Math.floor(genSecondsLeft / 60);
		const secs = genSecondsLeft % 60;
		genTimerDisplay.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
	}

	genTimerBtn.addEventListener('click', () => {
		if (genTimerInterval) {
			clearInterval(genTimerInterval);
			genTimerInterval = null;
			genTimerBtn.textContent = "Resume";
		} else {
			genTimerBtn.textContent = "Pause";
			genTimerInterval = setInterval(() => {
				if (genSecondsLeft > 0) {
					genSecondsLeft--;
					updateGenDisplay();
				} else {
					clearInterval(genTimerInterval);
					genTimerInterval = null;
					genTimerBtn.textContent = "Done!";
					try {
						const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
						const osc = audioCtx.createOscillator();
						const gain = audioCtx.createGain();
						osc.frequency.setValueAtTime(523, audioCtx.currentTime);
						gain.gain.setValueAtTime(0.04, audioCtx.currentTime);
						gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.4);
						osc.connect(gain);
						gain.connect(audioCtx.destination);
						osc.start();
						osc.stop(audioCtx.currentTime + 0.4);
					} catch(e){}
				}
			}, 1000);
		}
	});

	genCompleteBtn.addEventListener('click', () => {
		clearInterval(genTimerInterval);
		genTimerInterval = null;
		toggleWidget('general-widget', false);
		const points = Math.max(5, Math.round(genTotalSeconds / 15));
		window.dispatchEvent(new CustomEvent('activityCompleted', { 
			detail: { 
				points: points, 
				activityName: currentGenActivity.title,
				duration: Math.max(1, Math.round(genTotalSeconds / 60))
			} 
		}));
	});

	// Route to correct widget dynamically
	function launchTaskWidget(task) {
		// Hide side panel drawer
		sideDrawer.classList.add('-translate-x-full');
		activePanel = null;

		// Close other widgets to focus
		widgets.forEach(w => w.classList.add('hidden'));

		if (task.category === 'Wellness' && (task.title.toLowerCase().includes('breath') || task.title.toLowerCase().includes('meditate') || task.title.toLowerCase().includes('stretch'))) {
			toggleWidget('breathing-widget', true);
		} else if (task.category === 'Productivity' && (task.title.toLowerCase().includes('timer') || task.title.toLowerCase().includes('organize') || task.title.toLowerCase().includes('desk') || task.title.toLowerCase().includes('desktop'))) {
			toggleWidget('focustimer-widget', true);
		} else if (task.category === 'Learning' && (task.title.toLowerCase().includes('word') || task.title.toLowerCase().includes('shortcut') || task.title.toLowerCase().includes('phrase') || task.title.toLowerCase().includes('cybersecurity') || task.title.toLowerCase().includes('concept'))) {
			toggleWidget('typingsprint-widget', true);
		} else if (task.category === 'Reflection' && (task.title.toLowerCase().includes('journal') || task.title.toLowerCase().includes('write') || task.title.toLowerCase().includes('strengths') || task.title.toLowerCase().includes('compliment'))) {
			toggleWidget('journal-widget', true);
		} else if (task.category === 'Creativity' && (task.title.toLowerCase().includes('doodle') || task.title.toLowerCase().includes('sketch') || task.title.toLowerCase().includes('drawing') || task.title.toLowerCase().includes('sing'))) {
			toggleWidget('doodlecanvas-widget', true);
		} else {
			// Fallback: general timer stopwatch widget
			toggleWidget('general-widget', true);
			setupGeneralStopwatch(task);
		}
	}

	// 6. Handle activityCompleted global events
	const doneState = document.getElementById('done-state');
	const doneContent = document.getElementById('done-content');
	const finishBtn = document.getElementById('finish-reset');

	window.addEventListener('activityCompleted', (e) => {
		const { points, activityName } = e.detail;
		document.getElementById('done-points-earned').textContent = `+${points} Clarity Points`;
		document.getElementById('done-activity-name').textContent = `Completed: ${activityName}`;
		
		// Hide active widgets during done overlay
		widgets.forEach(w => w.classList.add('hidden'));

		doneState.classList.remove('hidden');
		setTimeout(() => {
			doneContent.classList.remove('opacity-0', 'scale-95');
			doneContent.classList.add('opacity-100', 'scale-100');
		}, 50);
	});

	function closeDoneScreen() {
		// Reset subcomponents
		window.dispatchEvent(new CustomEvent('betterthings_tool_reset'));

		doneContent.classList.remove('opacity-100', 'scale-100');
		doneContent.classList.add('opacity-0', 'scale-95');
		doneState.classList.add('opacity-0');
		
		setTimeout(() => {
			doneState.classList.add('hidden');
			doneState.classList.remove('opacity-0');
			doneContent.classList.remove('opacity-0');
			
			// Show Dashboard Hub!
			showDashboardHub(true);
		}, 500);
	}
	finishBtn.addEventListener('click', closeDoneScreen);

	function closeDoneScreen() {
		// Reset subcomponents
		window.dispatchEvent(new CustomEvent('betterthings_tool_reset'));

		doneContent.classList.remove('opacity-100', 'scale-100');
		doneContent.classList.add('opacity-0', 'scale-95');
		doneState.classList.add('opacity-0');
		
		setTimeout(() => {
			doneState.classList.add('hidden');
			doneState.classList.remove('opacity-0');
			doneContent.classList.remove('opacity-0');
			
			// Show Dashboard Hub!
			showDashboardHub(true);
		}, 500);
	}
	finishBtn.addEventListener('click', closeDoneScreen);

	// 7. Dashboard Hub State Management and Stats Loading
	function showDashboardHub(show = true) {
		const hub = document.getElementById('dashboard-hub');
		if (hub) {
			if (show) {
				hub.classList.remove('hidden');
				setTimeout(() => {
					hub.classList.remove('opacity-0', 'scale-95');
					hub.classList.add('opacity-100', 'scale-100');
				}, 20);
				// Hide other active widgets & onboarding flow
				showOnboardingFlow(false);
				widgets.forEach(w => w.classList.add('hidden'));
			} else {
				hub.classList.remove('opacity-100', 'scale-100');
				hub.classList.add('opacity-0', 'scale-95');
				setTimeout(() => hub.classList.add('hidden'), 300);
			}
		}
	}

	function loadHubStats() {
		const points = parseInt(localStorage.getItem('betterthings_points') || '0');
		const streak = parseInt(localStorage.getItem('betterthings_streak') || '0');
		const log = JSON.parse(localStorage.getItem('betterthings_log') || '[]');
		
		const today = new Date();
		const todayStr = `${today.getFullYear()}-${(today.getMonth()+1).toString().padStart(2, '0')}-${today.getDate().toString().padStart(2, '0')}`;
		
		const todayLog = log.filter(item => item.date === todayStr);
		const todayPoints = todayLog.reduce((sum, item) => sum + item.points, 0);
		const target = 50;
		const percent = Math.min(Math.round((todayPoints / target) * 100), 100);

		const pointsDisplay = document.getElementById('hub-points-display');
		const targetPercent = document.getElementById('hub-target-percent');
		const completionsCount = document.getElementById('hub-completions-count');
		const streakDays = document.getElementById('hub-streak-days');

		if (pointsDisplay) pointsDisplay.textContent = `${points} CP`;
		if (targetPercent) targetPercent.textContent = `${percent}%`;
		if (completionsCount) completionsCount.textContent = todayLog.length.toString();
		if (streakDays) {
			streakDays.textContent = streak > 0 ? `${streak} ${streak === 1 ? 'Day' : 'Days'}` : '0 Days';
		}
	}

	// 8. Onboarding Flow State Management & Statistics Loading
	let currentMood = 'Bored';
	let currentTimeLimit = 300; // default 5 min
	let matchingActivities = [];
	let selectedActivity = null;

	function showOnboardingFlow(show = true) {
		const flow = document.getElementById('onboarding-flow');
		if (flow) {
			if (show) {
				flow.classList.remove('hidden');
				setTimeout(() => {
					flow.classList.remove('opacity-0', 'scale-95');
					flow.classList.add('opacity-100', 'scale-100');
				}, 20);
				showDashboardHub(false);
				widgets.forEach(w => w.classList.add('hidden'));
				
				// Reset steps to welcome screen
				transitionStep('onboarding-step-mood', 'onboarding-step-welcome');
				transitionStep('onboarding-step-time', 'onboarding-step-welcome');
				transitionStep('onboarding-step-recommend', 'onboarding-step-welcome');
				
				loadOnboardingStats();
			} else {
				flow.classList.remove('opacity-100', 'scale-100');
				flow.classList.add('opacity-0', 'scale-95');
				setTimeout(() => flow.classList.add('hidden'), 300);
			}
		}
	}

	function loadOnboardingStats() {
		const points = parseInt(localStorage.getItem('betterthings_points') || '0');
		const streak = parseInt(localStorage.getItem('betterthings_streak') || '0');
		const minutesSaved = parseInt(localStorage.getItem('escapebored_minutes_saved') || '0');

		const statSaved = document.getElementById('onboarding-stat-saved');
		const statStreak = document.getElementById('onboarding-stat-streak');
		const statCp = document.getElementById('onboarding-stat-cp');

		if (statSaved) statSaved.textContent = `${minutesSaved} min`;
		if (statStreak) statStreak.textContent = `${streak} ${streak === 1 ? 'Day' : 'Days'}`;
		if (statCp) statCp.textContent = `${points}/50`;
	}

	function generateRecommendation() {
		const list = activities.filter(activity => {
			const seconds = parseTimeToSeconds(activity.time);
			return seconds <= currentTimeLimit;
		});

		let moodFiltered = list.filter(activity => {
			return activity.moods && activity.moods.includes(currentMood);
		});
		
		if (moodFiltered.length === 0) moodFiltered = list.length > 0 ? list : activities;

		matchingActivities = moodFiltered;
		shuffleRecommendation();
	}

	function shuffleRecommendation() {
		if (matchingActivities.length > 0) {
			const idx = Math.floor(Math.random() * matchingActivities.length);
			selectedActivity = matchingActivities[idx];
			
			document.getElementById('recommend-title').textContent = selectedActivity.title;
			document.getElementById('recommend-desc').textContent = selectedActivity.description;
			document.getElementById('recommend-category').textContent = selectedActivity.category;
			document.getElementById('recommend-time').textContent = selectedActivity.time;
		}
	}

	function transitionStep(fromId, toId) {
		const fromEl = document.getElementById(fromId);
		const toEl = document.getElementById(toId);
		if (fromEl && toEl) {
			fromEl.classList.add('hidden');
			toEl.classList.remove('hidden');
		}
	}

	// Home Button Listener (Returns to onboarding)
	const homeBtn = document.getElementById('sidebar-home-btn');
	if (homeBtn) {
		homeBtn.addEventListener('click', () => {
			sideDrawer.classList.add('-translate-x-full');
			activePanel = null;
			showOnboardingFlow(true);
			if (window.innerWidth < 768 && sidebar) {
				sidebar.classList.add('-left-16');
				sidebar.classList.remove('left-0');
			}
		});
	}

	// Onboarding Welcome Start
	const welcomeStartBtn = document.getElementById('welcome-start-btn');
	if (welcomeStartBtn) {
		welcomeStartBtn.addEventListener('click', () => {
			transitionStep('onboarding-step-welcome', 'onboarding-step-mood');
		});
	}

	// Mood Selector Buttons
	const moodBtns = document.querySelectorAll('.mood-btn');
	moodBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			currentMood = btn.getAttribute('data-mood');
			transitionStep('onboarding-step-mood', 'onboarding-step-time');
		});
	});

	// Time Selector Buttons
	const timeBtns = document.querySelectorAll('.time-btn');
	timeBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			currentTimeLimit = parseInt(btn.getAttribute('data-time'));
			generateRecommendation();
			transitionStep('onboarding-step-time', 'onboarding-step-recommend');
		});
	});

	// Onboarding Back Buttons
	const backBtns = document.querySelectorAll('.onboarding-back-btn');
	backBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const target = btn.getAttribute('data-to');
			if (target === 'mood') {
				transitionStep('onboarding-step-time', 'onboarding-step-mood');
			} else if (target === 'time') {
				transitionStep('onboarding-step-recommend', 'onboarding-step-time');
			}
		});
	});

	// Onboarding Shuffle Button
	const shuffleBtn = document.getElementById('recommend-shuffle-btn');
	if (shuffleBtn) {
		shuffleBtn.addEventListener('click', () => {
			shuffleRecommendation();
		});
	}

	// Onboarding Accept Recommendation Button
	const recommendAcceptBtn = document.getElementById('recommend-accept-btn');
	if (recommendAcceptBtn) {
		recommendAcceptBtn.addEventListener('click', () => {
			if (selectedActivity) {
				showOnboardingFlow(false);
				launchTaskWidget(selectedActivity);
			}
		});
	}

	// Skip Onboarding directly to Dashboard
	const skipBtn = document.getElementById('onboarding-skip-btn');
	if (skipBtn) {
		skipBtn.addEventListener('click', () => {
			showOnboardingFlow(false);
			showDashboardHub(true);
		});
	}

	// Mobile Sidebar Toggle
	const mobileToggle = document.getElementById('mobile-sidebar-toggle');
	const sidebar = document.getElementById('sidebar');
	if (mobileToggle && sidebar) {
		mobileToggle.addEventListener('click', (e) => {
			e.stopPropagation();
			sidebar.classList.toggle('-left-16');
			sidebar.classList.toggle('left-0');
		});

		document.addEventListener('click', (e) => {
			if (window.innerWidth < 768 && !sidebar.contains(e.target) && e.target !== mobileToggle) {
				sidebar.classList.add('-left-16');
				sidebar.classList.remove('left-0');
			}
		});
	}

	// Panic Button Listener inside Hub
	const hubPanicBtn = document.getElementById('hub-panic-btn');
	if (hubPanicBtn) {
		hubPanicBtn.addEventListener('click', () => {
			toggleWidget('grounding-widget', true);
			const widget = document.getElementById('grounding-widget');
			if (widget) {
				widget.style.top = '15%';
				widget.style.left = '30%';
			}
		});
	}

	// Tool Cards Listener inside Hub
	const hubToolCards = document.querySelectorAll('.hub-tool-card');
	hubToolCards.forEach(card => {
		card.addEventListener('click', () => {
			const widgetId = card.getAttribute('data-widget');
			if (widgetId) {
				const widget = document.getElementById(widgetId);
				if (widget) {
					// Position widget nicely
					widget.style.top = '15%';
					widget.style.left = '35%';
					toggleWidget(widgetId, true);
				}
			}
		});
	});

	// Register completion and refresh event listeners
	window.addEventListener('betterthings_refresh_view', () => {
		loadHubStats();
		loadOnboardingStats();
	});

	// Initial render & stats load
	renderDrawerTasks(currentTaskFilter);
	loadHubStats();
	loadOnboardingStats();
</script>

