	function getFilteredActivities(filter) {
		if (filter === 'quick') {
			return activities.filter(a => parseInt(a.time) <= 3);
		} else if (filter === 'procrastinating') {
			return activities.filter(a => ['Productivity', 'Reflection', 'Wellness'].includes(a.category));
		} else if (filter === 'Learning') {
			return activities.filter(a => a.category === 'Learning');
		}
		return activities;
	}

	function renderDrawerTasks(filter) {
		const list = getFilteredActivities(filter);
		activitiesListContainer.innerHTML = '';
		
		const shuffled = [...list].sort(() => 0.5 - Math.random()).slice(0, 10);
		
		shuffled.forEach(task => {
