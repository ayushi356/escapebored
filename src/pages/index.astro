---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

// Tools
import BreathingTool from '../components/tools/BreathingTool.astro';
import FocusTimer from '../components/tools/FocusTimer.astro';
import TypingSprint from '../components/tools/TypingSprint.astro';
import JournalTool from '../components/tools/JournalTool.astro';
import DoodleCanvas from '../components/tools/DoodleCanvas.astro';
import GroundingTool from '../components/tools/GroundingTool.astro';
import StatsDashboard from '../components/StatsDashboard.astro';

import activities from '../data/activities.json';
---

<Layout>
	<!-- Main full screen workspace wrapper -->
	<main id="workspace" class="h-screen w-screen relative overflow-hidden flex select-none font-sans">
		<!-- High Quality Background wallpaper layer -->
		<div id="workspace-bg" class="absolute inset-0 bg-cover bg-center transition-all duration-700 bg-[url('/pixel_lofi_street.jpg')] pointer-events-none z-0"></div>
		
		<!-- Warm Sepia/Amber sunset glow gradient overlay for cozy depth -->
		<div class="absolute inset-0 bg-gradient-to-tr from-[#2D231E]/20 via-[#DF9E56]/10 to-transparent pointer-events-none z-0"></div>

		<!-- RETREAT SHELF: Floating top-centered shelf navigation -->
		<header id="retreat-shelf" class="fixed top-6 left-1/2 -translate-x-1/2 z-50 flex items-center justify-between w-[92%] max-w-2xl px-6 h-14 bg-[#FAF6EE]/90 backdrop-blur-md border-2 border-[#8B7355]/20 rounded-full shadow-[0_6px_24px_rgba(44,35,30,0.12)] select-none">
			<button id="nav-home-btn" class="flex items-center gap-2 font-serif font-bold text-ink hover:text-primary transition-all cursor-pointer">
				<span class="text-xl">🕊️</span>
				<span class="hidden sm:inline-block text-sm font-semibold tracking-tight-sm">EscapeBored</span>
			</button>
			
			<nav class="flex items-center gap-1 sm:gap-2">
				<button class="nav-btn-cozy" data-panel="spaces-popover" title="Switch Space">
					<span>🏡</span> <span class="hidden md:inline">Spaces</span>
				</button>
				<button class="nav-btn-cozy" data-panel="sounds-popover" title="Ambient Mixer">
					<span>📻</span> <span class="hidden md:inline">Sounds</span>
				</button>
				<button class="nav-btn-cozy" data-panel="tasks-popover" title="All Activities">
					<span>🪵</span> <span class="hidden md:inline">Activities</span>
				</button>
				<button class="nav-btn-cozy" data-widget-toggle="stats-widget" title="Quiet Log">
					<span>📊</span> <span class="hidden md:inline">Progress</span>
				</button>
				<button id="nav-panic-btn" class="nav-btn-cozy text-error-deep font-semibold" title="Emergency Grounding">
					<span>🕯️</span> <span class="hidden md:inline">Calm</span>
				</button>
			</nav>
		</header>

		<!-- FLOATING POPOVER DROPDOWNS -->

		<!-- 1. Spaces Popover -->
		<div id="spaces-popover" class="cozy-popover fixed top-24 left-1/2 -translate-x-1/2 z-45 w-[90%] max-w-sm cozy-card p-6 hidden flex-col gap-4 max-h-[70vh] overflow-y-auto">
			<div class="flex items-center justify-between border-b border-hairline pb-2 mb-1">
				<h3 class="font-serif font-semibold text-ink text-sm flex items-center gap-1.5">🏡 Switch Space</h3>
				<button class="popover-close-btn text-[10px] font-mono text-mute hover:text-ink cursor-pointer">Close [x]</button>
			</div>
			<div class="flex flex-col gap-3">
				<div class="space-card cursor-pointer border-2 border-hairline hover:border-primary rounded-2xl overflow-hidden transition-all duration-300 group active-space" data-bg="/pixel_lofi_street.jpg">
					<div class="h-24 bg-cover bg-center bg-[url('/pixel_lofi_street.jpg')] group-hover:scale-102 transition-transform duration-500"></div>
					<div class="p-3 bg-canvas-soft flex justify-between items-center text-xs">
						<span class="font-semibold text-ink">Pixel Cyber City</span>
						<span class="text-[9px] font-mono bg-primary px-1.5 py-0.5 rounded-lg text-on-primary uppercase font-bold select-indicator">Active</span>
					</div>
				</div>
				<div class="space-card cursor-pointer border-2 border-hairline hover:border-primary rounded-2xl overflow-hidden transition-all duration-300 group" data-bg="/cozy_lofi_space.png">
					<div class="h-24 bg-cover bg-center bg-[url('/cozy_lofi_space.png')] group-hover:scale-102 transition-transform duration-500"></div>
					<div class="p-3 bg-canvas-soft flex justify-between items-center text-xs">
						<span class="font-semibold text-ink">Cozy Record Cafe</span>
						<span class="text-[9px] font-mono bg-primary px-1.5 py-0.5 rounded-lg text-on-primary uppercase font-bold select-indicator hidden">Active</span>
					</div>
				</div>
				<div class="space-card cursor-pointer border-2 border-hairline hover:border-primary rounded-2xl overflow-hidden transition-all duration-300 group" data-bg="/rainy_library_space.png">
					<div class="h-24 bg-cover bg-center bg-[url('/rainy_library_space.png')] group-hover:scale-102 transition-transform duration-500"></div>
					<div class="p-3 bg-canvas-soft flex justify-between items-center text-xs">
						<span class="font-semibold text-ink">Rainy Library</span>
						<span class="text-[9px] font-mono bg-primary px-1.5 py-0.5 rounded-lg text-on-primary uppercase font-bold select-indicator hidden">Active</span>
					</div>
				</div>
			</div>
		</div>

		<!-- 2. Sounds Popover -->
		<div id="sounds-popover" class="cozy-popover fixed top-24 left-1/2 -translate-x-1/2 z-45 w-[90%] max-w-md cozy-card p-6 hidden flex-col gap-4 max-h-[70vh] overflow-y-auto text-[#2D231E]">
			<div class="flex items-center justify-between border-b border-hairline pb-2 mb-1">
				<h3 class="font-serif font-semibold text-ink text-sm flex items-center gap-1.5">📻 Cozy Mixer & Radio</h3>
				<button class="popover-close-btn text-[10px] font-mono text-mute hover:text-ink cursor-pointer">Close [x]</button>
			</div>
			
			<div class="flex flex-col gap-4">
				<!-- Audio Presets -->
				<div class="bg-canvas-soft p-4 rounded-2xl border border-hairline flex flex-col gap-2.5">
					<span class="text-[9px] font-mono text-mute uppercase tracking-wider block border-b border-hairline pb-1.5">Atmosphere Presets</span>
					<div class="grid grid-cols-2 gap-2">
						<button id="preset-deep-focus" class="preset-audio-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft-2 transition-all font-semibold cursor-pointer" data-preset="deep-focus">⚡ Deep Focus</button>
						<button id="preset-rainy-cafe" class="preset-audio-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft-2 transition-all font-semibold cursor-pointer" data-preset="rainy-cafe">☕ Rainy Cafe</button>
						<button id="preset-cozy-study" class="preset-audio-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft-2 transition-all font-semibold cursor-pointer" data-preset="cozy-study">📚 Cozy Study</button>
						<button id="preset-night-coding" class="preset-audio-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft-2 transition-all font-semibold cursor-pointer" data-preset="night-coding">🌙 Night Coding</button>
					</div>
				</div>

				<!-- Music player -->
				<div class="bg-canvas-soft p-4 rounded-2xl border border-hairline flex flex-col gap-3">
					<span class="text-[9px] font-mono text-mute uppercase tracking-wider block border-b border-hairline pb-1.5">Lofi Music Player</span>
					<div class="flex flex-col gap-1">
						<span class="text-[9px] font-mono text-mute uppercase">Channel</span>
						<select id="lofi-track-select" class="w-full h-9 px-3 text-xs rounded-xl border border-hairline bg-canvas text-ink font-sans outline-none focus:border-primary transition-all">
							<option value="https://stream.laut.fm/lofi">📻 24/7 Lofi Focus Radio</option>
							<option value="https://stream.laut.fm/chilledbeats">🎵 Dreamy Chillout Beats</option>
							<option value="https://stream.laut.fm/chillout-radio">🍵 Lofi Ambient Cafe</option>
							<option value="ambient-only">🔇 Ambient Only (No Music)</option>
						</select>
					</div>
					<div class="flex justify-between items-center mt-1">
						<span class="text-xs font-semibold text-ink" id="current-music-label">Lofi Focus Radio</span>
						<button id="lofi-play-btn" class="h-8 px-4 text-xs bg-primary text-on-primary font-semibold rounded-full hover:bg-link-deep transition-all cursor-pointer">Play</button>
					</div>
					<audio id="lofi-audio" loop src="https://stream.laut.fm/lofi" class="hidden" crossorigin="anonymous"></audio>
					<div class="flex items-center gap-2 mt-1">
						<span class="text-[9px] font-mono text-mute w-8">MUSIC</span>
						<input type="range" id="lofi-volume" min="0" max="1" step="0.05" value="0.4" class="w-full h-1 bg-hairline-strong rounded accent-primary cursor-pointer" />
					</div>
				</div>

				<!-- Synthesizers -->
				<div class="bg-canvas-soft p-4 rounded-2xl border border-hairline flex flex-col gap-4">
					<span class="text-[9px] font-mono text-mute uppercase tracking-wider block border-b border-hairline pb-1.5">Ambient Synthesizer Mixer</span>
					<div class="flex flex-col gap-4">
						<!-- Rain -->
						<div class="flex flex-col gap-1.5">
							<div class="flex items-center justify-between text-xs">
								<span class="text-ink flex items-center gap-2 font-medium">
									<input type="checkbox" id="synth-rain-toggle" class="cursor-pointer accent-primary" />
									🌧️ Soft Rain
								</span>
								<span id="rain-vol-percent" class="text-[10px] font-mono text-mute">30%</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="text-[9px] font-mono text-mute w-8">RAIN</span>
								<input type="range" id="synth-rain-volume" min="0" max="1" step="0.05" value="0.3" class="w-full h-1 bg-hairline-strong rounded accent-primary cursor-pointer" />
							</div>
						</div>
						<!-- Ocean -->
						<div class="flex flex-col gap-1.5">
							<div class="flex items-center justify-between text-xs">
								<span class="text-ink flex items-center gap-2 font-medium">
									<input type="checkbox" id="synth-ocean-toggle" class="cursor-pointer accent-primary" />
									🌊 Ocean Swells
								</span>
								<span id="ocean-vol-percent" class="text-[10px] font-mono text-mute">20%</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="text-[9px] font-mono text-mute w-8">OCEAN</span>
								<input type="range" id="synth-ocean-volume" min="0" max="1" step="0.05" value="0.2" class="w-full h-1 bg-hairline-strong rounded accent-primary cursor-pointer" />
							</div>
						</div>
						<!-- Drone -->
						<div class="flex flex-col gap-1.5">
							<div class="flex items-center justify-between text-xs">
								<span class="text-ink flex items-center gap-2 font-medium">
									<input type="checkbox" id="synth-drone-toggle" class="cursor-pointer accent-primary" />
									🧘 Hearth Hum
								</span>
								<span id="drone-vol-percent" class="text-[10px] font-mono text-mute">20%</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="text-[9px] font-mono text-mute w-8">HUM</span>
								<input type="range" id="synth-drone-volume" min="0" max="1" step="0.05" value="0.2" class="w-full h-1 bg-hairline-strong rounded accent-primary cursor-pointer" />
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- 3. Activities Popover -->
		<div id="tasks-popover" class="cozy-popover fixed top-24 left-1/2 -translate-x-1/2 z-45 w-[90%] max-w-md cozy-card p-6 hidden flex-col gap-4 max-h-[70vh] overflow-y-auto">
			<div class="flex items-center justify-between border-b border-hairline pb-2 mb-1">
				<h3 class="font-serif font-semibold text-ink text-sm flex items-center gap-1.5">🪵 Mindful Activities</h3>
				<button class="popover-close-btn text-[10px] font-mono text-mute hover:text-ink cursor-pointer">Close [x]</button>
			</div>
			<div class="grid grid-cols-2 gap-2 mb-1">
				<button class="task-filter-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft transition-all font-semibold active-filter animate-all" data-filter="any">Show All</button>
				<button class="task-filter-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft transition-all font-semibold animate-all" data-filter="quick">Under 3 Min</button>
				<button class="task-filter-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft transition-all font-semibold animate-all" data-filter="Learning">Concepts</button>
				<button class="task-filter-btn text-[10px] border border-hairline bg-canvas py-1.5 rounded-xl hover:bg-canvas-soft transition-all font-semibold animate-all" data-filter="procrastinating">Break Stall</button>
			</div>
			<div id="drawer-activities-list" class="flex flex-col gap-2 overflow-y-auto pr-1">
				<!-- Injected in script -->
			</div>
		</div>


		<!-- MAIN CENTRAL ONBOARDING FLOW -->
		<div id="onboarding-flow" class="absolute inset-0 flex items-center justify-center pointer-events-none z-20 overflow-y-auto py-20 px-4 transition-all duration-300 transform scale-100 opacity-100">
			<div class="w-full max-w-lg cozy-card p-8 shadow-level-5 flex flex-col gap-6 pointer-events-auto transition-all duration-500 max-h-[90vh] overflow-y-auto text-center text-[#2D231E] relative bg-[#FAF6EE]">
				
				<button id="onboarding-skip-btn" class="absolute top-4 right-5 text-[10px] font-mono text-mute hover:text-ink transition-colors cursor-pointer" title="Go to Dashboard">Skip to Guestbook →</button>

				<!-- STEP 0: Welcome -->
				<div id="onboarding-step-welcome" class="flex flex-col gap-5 py-4">
					<div class="flex flex-col items-center gap-2">
						<div class="w-16 h-16 rounded-2xl bg-canvas-soft border-2 border-hairline flex items-center justify-center text-3xl shadow-sm select-none">
							🕊️
						</div>
						<h1 class="text-4xl font-serif font-bold tracking-tight-md text-ink mt-2">EscapeBored</h1>
						<p class="text-[10px] text-mute uppercase font-mono tracking-widest">A Cozy Space to Find Focus</p>
					</div>

					<p class="text-sm text-body max-w-sm mx-auto leading-relaxed">
						Trade doomscrolling and digital fatigue for a peaceful moment of presence, learning, or creative sketching.
					</p>

					<div class="py-2">
						<button id="welcome-start-btn" class="w-full h-12 bg-primary text-on-primary hover:bg-link-deep font-semibold rounded-2xl text-sm transition-all duration-300 shadow-md active:scale-95 cursor-pointer">
							I'm Bored — Give Me Something To Do
						</button>
					</div>

					<!-- stats summary -->
					<div class="flex items-center justify-around bg-canvas-soft border-2 border-hairline rounded-2xl p-4 text-xs mt-2 text-[#6D554B]">
						<div class="flex flex-col items-center gap-0.5">
							<span class="text-[9px] font-mono text-mute uppercase">Quiet Time</span>
							<span id="onboarding-stat-saved" class="font-bold text-ink">0 min</span>
						</div>
						<div class="w-[2px] h-6 bg-[#8B7355]/10"></div>
						<div class="flex flex-col items-center gap-0.5">
							<span class="text-[9px] font-mono text-mute uppercase">Streak</span>
							<span id="onboarding-stat-streak" class="font-bold text-ink">0 Days</span>
						</div>
						<div class="w-[2px] h-6 bg-[#8B7355]/10"></div>
						<div class="flex flex-col items-center gap-0.5">
							<span class="text-[9px] font-mono text-mute uppercase">Clarity</span>
							<span id="onboarding-stat-cp" class="font-bold text-primary">0/50 CP</span>
						</div>
					</div>
				</div>

				<!-- STEP 1: Mood -->
				<div id="onboarding-step-mood" class="hidden flex flex-col gap-5 py-2">
					<div class="flex flex-col gap-1">
						<h2 class="text-2xl font-serif font-bold text-ink tracking-tight-sm">How is your mind right now?</h2>
						<p class="text-xs text-mute">We'll find an activity that fits your current state.</p>
					</div>
					
					<div class="flex flex-col gap-3 max-h-[45vh] overflow-y-auto pr-1">
						<button class="mood-btn-cozy" data-mood="Bored">
							<span class="text-2xl">🥱</span>
							<div class="text-left">
								<div class="font-bold text-sm text-ink leading-tight">Bored</div>
								<div class="text-[10px] text-mute leading-snug mt-0.5">Looking for a quick curiosity spark or strange concept</div>
							</div>
						</button>
						<button class="mood-btn-cozy" data-mood="Stressed">
							<span class="text-2xl">😰</span>
							<div class="text-left">
								<div class="font-bold text-sm text-ink leading-tight">Stressed</div>
								<div class="text-[10px] text-mute leading-snug mt-0.5">Need a calming breathing routine or quick grounding</div>
							</div>
						</button>
						<button class="mood-btn-cozy" data-mood="Restless">
							<span class="text-2xl">🌀</span>
							<div class="text-left">
								<div class="font-bold text-sm text-ink leading-tight">Restless</div>
								<div class="text-[10px] text-mute leading-snug mt-0.5">High physical energy, need movement or typing sprint</div>
							</div>
						</button>
						<button class="mood-btn-cozy" data-mood="Curious">
							<span class="text-2xl">💡</span>
							<div class="text-left">
								<div class="font-bold text-sm text-ink leading-tight">Curious</div>
								<div class="text-[10px] text-mute leading-snug mt-0.5">Want to learn something cool or solve a quick puzzle</div>
							</div>
						</button>
						<button class="mood-btn-cozy" data-mood="Unmotivated">
							<span class="text-2xl">🥀</span>
							<div class="text-left">
								<div class="font-bold text-sm text-ink leading-tight">Unmotivated</div>
								<div class="text-[10px] text-mute leading-snug mt-0.5">Low energy, need a tiny 1-minute win to reset</div>
							</div>
						</button>
					</div>
				</div>

				<!-- STEP 2: Time Selection -->
				<div id="onboarding-step-time" class="hidden flex flex-col gap-6 py-2">
					<div class="flex flex-col gap-1">
						<h2 class="text-2xl font-serif font-bold text-ink tracking-tight-sm">How much time do you have?</h2>
						<p class="text-xs text-mute">Even 30 seconds is enough to escape the scrolling loop.</p>
					</div>
					
					<div class="grid grid-cols-2 gap-3">
						<button class="time-btn-cozy" data-time="30">
							<span class="text-2xl">⚡</span>
							<span class="font-bold text-xs text-ink mt-1">30 Seconds</span>
						</button>
						<button class="time-btn-cozy" data-time="120">
							<span class="text-2xl">⏳</span>
							<span class="font-bold text-xs text-ink mt-1">2 Minutes</span>
						</button>
						<button class="time-btn-cozy" data-time="300">
							<span class="text-2xl">⏱️</span>
							<span class="font-bold text-xs text-ink mt-1">5 Minutes</span>
						</button>
						<button class="time-btn-cozy" data-time="900">
							<span class="text-2xl">🕰️</span>
							<span class="font-bold text-xs text-ink mt-1">15 Minutes</span>
						</button>
					</div>

					<button class="onboarding-back-btn text-xs text-mute hover:text-ink transition-colors underline cursor-pointer mt-4" data-to="mood">← Back to Mood</button>
				</div>

				<!-- STEP 3: Recommended Activity -->
				<div id="onboarding-step-recommend" class="hidden flex flex-col gap-5 py-2">
					<div class="flex flex-col gap-1">
						<h2 class="text-2xl font-serif font-bold text-ink tracking-tight-sm">Your Mindful Nook</h2>
						<p class="text-xs text-mute">Handpicked specifically for your current energy.</p>
					</div>

					<!-- card layout -->
					<div class="bg-canvas-soft border-2 border-hairline rounded-2xl p-5 text-left flex flex-col gap-3">
						<div class="flex justify-between items-center">
							<span id="recommend-category" class="text-[9px] font-mono font-bold text-primary uppercase tracking-wider bg-canvas px-2.5 py-0.5 rounded-full border border-hairline">Category</span>
							<span id="recommend-time" class="text-[9px] font-mono font-bold text-primary uppercase tracking-wider bg-canvas px-2.5 py-0.5 rounded-full border border-hairline">Time</span>
						</div>
						<div>
							<h3 id="recommend-title" class="text-base font-serif font-bold text-ink leading-tight">Activity Title</h3>
							<p id="recommend-desc" class="text-xs text-body mt-2 leading-relaxed">Activity description details.</p>
						</div>
					</div>

					<div class="flex flex-col gap-3">
						<button id="recommend-accept-btn" class="w-full h-11 bg-primary text-on-primary hover:bg-link-deep font-semibold rounded-2xl text-sm transition-all shadow-sm cursor-pointer active:scale-95">
							Let's Do It! →
						</button>
						
						<div class="flex justify-between items-center px-2">
							<button id="recommend-shuffle-btn" class="text-xs text-primary hover:text-link-deep font-bold transition-colors cursor-pointer">Try Another Activity</button>
							<button class="onboarding-back-btn text-xs text-mute hover:text-ink transition-colors cursor-pointer" data-to="time">← Back to Time</button>
						</div>
					</div>
				</div>

			</div>
		</div>


		<!-- MAIN CENTRAL GUESTBOOK DASHBOARD HUB -->
		<div id="dashboard-hub" class="absolute inset-0 flex items-center justify-center pointer-events-none z-10 overflow-y-auto py-20 px-4 transition-all duration-300 transform scale-95 opacity-0 hidden">
			<div class="w-full max-w-4xl cozy-card p-8 shadow-level-5 flex flex-col gap-6 pointer-events-auto transition-all duration-500 max-h-[90vh] overflow-y-auto text-[#2D231E] bg-[#FAF6EE]">
				
				<!-- Header section -->
				<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-hairline pb-5">
					<div>
						<h1 class="text-3xl font-serif font-bold tracking-tight-sm text-ink">Welcome to the Retreat</h1>
						<p class="text-xs text-mute mt-1">Take a deep breath and select a mindful station below.</p>
					</div>
					
					<div class="flex items-center gap-3 bg-canvas-soft border-2 border-hairline rounded-2xl px-4 py-2 text-xs">
						<span class="text-xl">🔥</span>
						<div>
