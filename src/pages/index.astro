	function launchTaskWidget(task) {
		closeAllPopovers();

		// Hide active widgets during done overlay
		nookWidgets.forEach(w => w.classList.add('hidden'));

		if (task.category === 'Wellness' && (task.title.toLowerCase().includes('breath') || task.title.toLowerCase().includes('meditate') || task.title.toLowerCase().includes('stretch'))) {
			toggleWidget('breathing-widget', true);
		} else if (task.category === 'Productivity' && (task.title.toLowerCase().includes('timer') || task.title.toLowerCase().includes('organize') || task.title.toLowerCase().includes('desk') || task.title.toLowerCase().includes('desktop'))) {
			toggleWidget('focustimer-widget', true);
		} else if (task.category === 'Learning' && (task.title.toLowerCase().includes('word') || task.title.toLowerCase().includes('shortcut') || task.title.toLowerCase().includes('phrase') || task.title.toLowerCase().includes('cybersecurity') || task.title.toLowerCase().includes('concept'))) {
			toggleWidget('typingsprint-widget', true);
		} else if (task.category === 'Reflection' && (task.title.toLowerCase().includes('journal') || task.title.toLowerCase().includes('write') || task.title.toLowerCase().includes('strengths') || task.title.toLowerCase().includes('compliment'))) {
			toggleWidget('journal-widget', true);
		} else if (task.category === 'Creativity' && (task.title.toLowerCase().includes('doodle') || task.title.toLowerCase().includes('sketch') || task.title.toLowerCase().includes('drawing') || task.title.toLowerCase().includes('sing'))) {
			toggleWidget('doodlecanvas-widget', true);
		} else {
			// Fallback: general timer stopwatch
			toggleWidget('general-widget', true);
			setupGeneralStopwatch(task);
		}
	}

