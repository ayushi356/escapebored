<script define:vars={{ activities }}>
	// Cozy Popovers, Nav Toggles, and Centered Modal Routing System
	const cozyPopovers = document.querySelectorAll('.cozy-popover');
	const nookContainer = document.getElementById('nook-container');
	const nookWidgets = document.querySelectorAll('.cozy-nook-widget');
	
	function closeAllPopovers() {
		cozyPopovers.forEach(p => p.classList.add('hidden'));
	}

	// Popovers Trigger Toggling
	const panelNavBtns = document.querySelectorAll('[data-panel]');
	panelNavBtns.forEach(btn => {
		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const targetId = btn.getAttribute('data-panel');
			const popover = document.getElementById(targetId);
			
			if (popover) {
				const wasHidden = popover.classList.contains('hidden');
				closeAllPopovers();
				
				if (wasHidden) {
					popover.classList.remove('hidden');
				}
			}
		});
	});

	// Close Popovers on Click Outside
	document.addEventListener('click', (e) => {
		const isPopoverClick = Array.from(cozyPopovers).some(p => p.contains(e.target));
		const isToggleClick = Array.from(panelNavBtns).some(b => b.contains(e.target));
		
		if (!isPopoverClick && !isToggleClick) {
			closeAllPopovers();
		}
	});

	// Wire close buttons inside Popovers
	document.querySelectorAll('.popover-close-btn').forEach(btn => {
		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			closeAllPopovers();
		});
	});

	// Toggle Nook Centered Widgets visibility
	function toggleWidget(id, show = true) {
		const widget = document.getElementById(id);
		if (widget) {
			if (show) {
				closeAllPopovers();
				// Hide other active widgets in container
				nookWidgets.forEach(w => w.classList.add('hidden'));
				
				// Show container and this widget
				nookContainer.classList.remove('hidden');
				nookContainer.classList.add('flex');
				widget.classList.remove('hidden');
				
				showDashboardHub(false);
				showOnboardingFlow(false);
			} else {
				widget.classList.add('hidden');
				
				// Check if any other widgets are open
				const anyOpen = Array.from(nookWidgets).some(w => !w.classList.contains('hidden'));
				if (!anyOpen) {
					nookContainer.classList.add('hidden');
					nookContainer.classList.remove('flex');
					showDashboardHub(true);
				}
			}
		}
	}

	// Wire widget togglers
	const widgetToggleBtns = document.querySelectorAll('[data-widget-toggle]');
	widgetToggleBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const widgetId = btn.getAttribute('data-widget-toggle');
			toggleWidget(widgetId, true);
		});
	});

	// Wire widget close buttons
	const closeBtns = document.querySelectorAll('.widget-close-btn-cozy');
	closeBtns.forEach(btn => {
		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const widget = btn.closest('.cozy-nook-widget');
			if (widget) {
				toggleWidget(widget.id, false);
				// Dispatch reset inside sub-tools
				window.dispatchEvent(new CustomEvent('betterthings_tool_reset'));
			}
		});
	});

	// Emergency Panic Grounding trigger
	const panicBtns = [document.getElementById('nav-panic-btn'), document.getElementById('hub-panic-btn')];
	panicBtns.forEach(btn => {
		if (btn) {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				toggleWidget('grounding-widget', true);
			});
		}
	});

	// 2. Spaces background switcher
	const spaceCards = document.querySelectorAll('.space-card');
	spaceCards.forEach(card => {
		card.addEventListener('click', () => {
			spaceCards.forEach(c => {
				c.classList.remove('border-primary', 'active-space');
				c.classList.add('border-hairline');
				c.querySelector('.select-indicator').classList.add('hidden');
			});
			card.classList.add('border-primary', 'active-space');
			card.classList.remove('border-hairline');
			card.querySelector('.select-indicator').classList.remove('hidden');
			
			const bg = card.getAttribute('data-bg');
			document.getElementById('workspace-bg').style.backgroundImage = `url('${bg}')`;
		});
	});

	// 3. Sound panel music and global audio synthesizers
	const playBtn = document.getElementById('lofi-play-btn');
	const audioEl = document.getElementById('lofi-audio');
	const volInput = document.getElementById('lofi-volume');
	const lofiTrackSelect = document.getElementById('lofi-track-select');
	const currentMusicLabel = document.getElementById('current-music-label');
	let audioFadeInterval = null;

	function fadeInAudio(audioElement, targetVolume, duration = 1500) {
		clearInterval(audioFadeInterval);
		audioElement.volume = 0;
		return audioElement.play().then(() => {
			const start = Date.now();
			audioFadeInterval = setInterval(() => {
				const elapsed = Date.now() - start;
				const progress = Math.min(elapsed / duration, 1);
				audioElement.volume = progress * targetVolume;
				if (progress >= 1) {
					clearInterval(audioFadeInterval);
				}
			}, 30);
		}).catch(err => console.log("Audio play interrupted/blocked:", err));
	}

	function fadeOutAudio(audioElement, duration = 1000) {
		clearInterval(audioFadeInterval);
		const start = Date.now();
		const initialVol = audioElement.volume;
		audioFadeInterval = setInterval(() => {
			const elapsed = Date.now() - start;
			const progress = Math.min(elapsed / duration, 1);
			audioElement.volume = initialVol * (1 - progress);
			if (progress >= 1) {
				clearInterval(audioFadeInterval);
				audioElement.pause();
				audioElement.volume = initialVol;
			}
		}, 30);
	}

	playBtn.addEventListener('click', () => {
		if (audioEl.paused) {
			fadeInAudio(audioEl, parseFloat(volInput.value)).then(() => {
				playBtn.textContent = 'Pause';
				playBtn.classList.add('bg-primary', 'text-on-primary');
			});
		} else {
			fadeOutAudio(audioEl);
			playBtn.textContent = 'Play';
			playBtn.classList.remove('bg-primary', 'text-on-primary');
		}
	});

	volInput.addEventListener('input', () => {
		if (!audioEl.paused) {
			audioEl.volume = parseFloat(volInput.value);
		}
	});

	lofiTrackSelect.addEventListener('change', () => {
		const selectedUrl = lofiTrackSelect.value;
		const selectedText = lofiTrackSelect.options[lofiTrackSelect.selectedIndex].text;
		currentMusicLabel.textContent = selectedText.split(' ').slice(1).join(' '); // remove emoji

		if (selectedUrl === 'ambient-only') {
			if (!audioEl.paused) {
				fadeOutAudio(audioEl);
				playBtn.textContent = 'Play';
				playBtn.classList.remove('bg-primary', 'text-on-primary');
			}
			playBtn.disabled = true;
			playBtn.classList.add('opacity-30', 'pointer-events-none');
		} else {
			playBtn.disabled = false;
			playBtn.classList.remove('opacity-30', 'pointer-events-none');
			const wasPlaying = !audioEl.paused;
			audioEl.src = selectedUrl;
			if (wasPlaying) {
				fadeInAudio(audioEl, parseFloat(volInput.value));
			}
		}
	});

	// Global synthesizers
	let synthCtx = null;
	let rainNode = null;
	let rainGain = null;
	let wavesNode = null;
	let wavesGain = null;
	let wavesModulator = null;
	let droneOscillators = [];
	let droneGain = null;

	let rainVol = 0.3;
	let oceanVol = 0.2;
	let droneVol = 0.2;

	function initSynthCtx() {
		if (!synthCtx) {
			synthCtx = new (window.AudioContext || window.webkitAudioContext)();
		}
		if (synthCtx.state === 'suspended') {
			synthCtx.resume();
		}
	}

	function createNoiseBuffer() {
		const size = synthCtx.sampleRate * 2;
		const buffer = synthCtx.createBuffer(1, size, synthCtx.sampleRate);
		const output = buffer.getChannelData(0);
		for (let i = 0; i < size; i++) {
			output[i] = Math.random() * 2 - 1;
		}
		return buffer;
	}

	// Rain
	function startRain() {
		initSynthCtx();
		if (rainNode) return;
		const buffer = createNoiseBuffer();
		rainNode = synthCtx.createBufferSource();
		rainNode.buffer = buffer;
		rainNode.loop = true;

		const filter = synthCtx.createBiquadFilter();
		filter.type = 'lowpass';
		filter.frequency.setValueAtTime(500, synthCtx.currentTime);

		const filter2 = synthCtx.createBiquadFilter();
		filter2.type = 'bandpass';
		filter2.frequency.setValueAtTime(800, synthCtx.currentTime);
		filter2.Q.setValueAtTime(0.8, synthCtx.currentTime);

		rainGain = synthCtx.createGain();
		rainGain.gain.setValueAtTime(0, synthCtx.currentTime);
		rainGain.gain.linearRampToValueAtTime(rainVol, synthCtx.currentTime + 1.5);

		rainNode.connect(filter);
		filter.connect(filter2);
		filter2.connect(rainGain);
		rainGain.connect(synthCtx.destination);
		rainNode.start(0);
	}

	function stopRain() {
		if (rainNode && rainGain) {
			const nodeToStop = rainNode;
			const gainToFade = rainGain;
			rainNode = null;
			rainGain = null;

			gainToFade.gain.setValueAtTime(gainToFade.gain.value, synthCtx.currentTime);
			gainToFade.gain.linearRampToValueAtTime(0, synthCtx.currentTime + 1.0);
			setTimeout(() => {
				try { nodeToStop.stop(); } catch(e){}
				nodeToStop.disconnect();
				gainToFade.disconnect();
			}, 1000);
		}
	}

	// Waves
	function startWaves() {
		initSynthCtx();
		if (wavesNode) return;
		const buffer = createNoiseBuffer();
		wavesNode = synthCtx.createBufferSource();
		wavesNode.buffer = buffer;
		wavesNode.loop = true;

		const filter = synthCtx.createBiquadFilter();
		filter.type = 'lowpass';
		filter.frequency.setValueAtTime(250, synthCtx.currentTime);

		wavesGain = synthCtx.createGain();
		wavesGain.gain.setValueAtTime(0, synthCtx.currentTime);
		wavesGain.gain.linearRampToValueAtTime(oceanVol, synthCtx.currentTime + 2.0);

		wavesModulator = synthCtx.createOscillator();
		wavesModulator.frequency.setValueAtTime(0.08, synthCtx.currentTime);
		const modGain = synthCtx.createGain();
		modGain.gain.setValueAtTime(150, synthCtx.currentTime);

		wavesModulator.connect(modGain);
		modGain.connect(filter.frequency);

		const panner = synthCtx.createStereoPanner ? synthCtx.createStereoPanner() : null;
		if (panner) {
			const panLfo = synthCtx.createOscillator();
			panLfo.frequency.setValueAtTime(0.05, synthCtx.currentTime);
			const panGain = synthCtx.createGain();
			panGain.gain.setValueAtTime(0.6, synthCtx.currentTime);
			
			panLfo.connect(panGain);
			panGain.connect(panner.pan);
			panLfo.start(0);
			
			wavesNode.connect(filter);
			filter.connect(wavesGain);
			wavesGain.connect(panner);
			panner.connect(synthCtx.destination);
			
			wavesNode.panLfo = panLfo;
			wavesNode.panner = panner;
		} else {
			wavesNode.connect(filter);
			filter.connect(wavesGain);
			wavesGain.connect(synthCtx.destination);
		}

		wavesModulator.start(0);
		wavesNode.start(0);
	}

	function stopWaves() {
		if (wavesNode && wavesGain) {
			const nodeToStop = wavesNode;
			const modulatorToStop = wavesModulator;
			const gainToFade = wavesGain;
			
			wavesNode = null;
			wavesModulator = null;
			wavesGain = null;

			gainToFade.gain.setValueAtTime(gainToFade.gain.value, synthCtx.currentTime);
			gainToFade.gain.linearRampToValueAtTime(0, synthCtx.currentTime + 1.2);
			
			setTimeout(() => {
				try { nodeToStop.stop(); } catch(e){}
				try { modulatorToStop.stop(); } catch(e){}
				if (nodeToStop.panLfo) {
					try { nodeToStop.panLfo.stop(); } catch(e){}
					nodeToStop.panLfo.disconnect();
				}
				if (nodeToStop.panner) {
					nodeToStop.panner.disconnect();
				}
				nodeToStop.disconnect();
				modulatorToStop.disconnect();
				gainToFade.disconnect();
			}, 1200);
		}
	}

	// Drone
	function startDrone() {
		initSynthCtx();
		if (droneOscillators.length > 0) return;
		const frequencies = [130.81, 196.00, 261.63, 329.63]; // C3, G3, C4, E4
		
		droneGain = synthCtx.createGain();
		droneGain.gain.setValueAtTime(0, synthCtx.currentTime);
		droneGain.gain.linearRampToValueAtTime(droneVol, synthCtx.currentTime + 2.0);

		const oscillators = frequencies.map((freq, idx) => {
			const osc = synthCtx.createOscillator();
			osc.type = 'sine';
			osc.frequency.setValueAtTime(freq + (Math.random() - 0.5) * 0.6, synthCtx.currentTime);
			
			const trem = synthCtx.createOscillator();
			trem.frequency.setValueAtTime(0.20 + idx * 0.05, synthCtx.currentTime);
			const tremGain = synthCtx.createGain();
			tremGain.gain.setValueAtTime(0.03, synthCtx.currentTime);
			
			const oscGain = synthCtx.createGain();
			oscGain.gain.setValueAtTime(0.22, synthCtx.currentTime);
			
			trem.connect(tremGain);
			tremGain.connect(oscGain.gain);
			
			osc.connect(oscGain);
			oscGain.connect(droneGain);
			
			trem.start(0);
			osc.start(0);
			
			return { osc, trem };
		});

		const subOsc = synthCtx.createOscillator();
		subOsc.type = 'triangle';
		subOsc.frequency.setValueAtTime(65.41, synthCtx.currentTime);
		const subGain = synthCtx.createGain();
		subGain.gain.setValueAtTime(0.15, synthCtx.currentTime);
		subOsc.connect(subGain);
		subGain.connect(droneGain);
		subOsc.start(0);

		const filter = synthCtx.createBiquadFilter();
		filter.type = 'lowpass';
		filter.frequency.setValueAtTime(280, synthCtx.currentTime);

		droneGain.connect(filter);
		filter.connect(synthCtx.destination);

		droneOscillators = [...oscillators, { osc: subOsc, trem: null }];
	}

	function stopDrone() {
		if (droneOscillators.length > 0 && droneGain) {
			const oscsToStop = droneOscillators;
			const gainToFade = droneGain;
			
			droneOscillators = [];
			droneGain = null;

			gainToFade.gain.setValueAtTime(gainToFade.gain.value, synthCtx.currentTime);
			gainToFade.gain.linearRampToValueAtTime(0, synthCtx.currentTime + 1.5);

			setTimeout(() => {
				oscsToStop.forEach(({ osc, trem }) => {
					try { osc.stop(); } catch(e){}
					osc.disconnect();
					if (trem) {
						try { trem.stop(); } catch(e){}
						trem.disconnect();
					}
				});
				gainToFade.disconnect();
			}, 1500);
		}
	}

