	function loadHubStats() {
		const points = parseInt(localStorage.getItem('betterthings_points') || '0');
		const streak = parseInt(localStorage.getItem('betterthings_streak') || '0');
		const log = JSON.parse(localStorage.getItem('betterthings_log') || '[]');
		
		const today = new Date();
		const todayStr = `${today.getFullYear()}-${(today.getMonth()+1).toString().padStart(2, '0')}-${today.getDate().toString().padStart(2, '0')}`;
		
		const todayLog = log.filter(item => item.date === todayStr);
		const todayPoints = todayLog.reduce((sum, item) => sum + item.points, 0);
		const target = 50;
		const percent = Math.min(Math.round((todayPoints / target) * 100), 100);

		const pointsDisplay = document.getElementById('hub-points-display');
		const targetPercent = document.getElementById('hub-target-percent');
		const completionsCount = document.getElementById('hub-completions-count');
		const streakDays = document.getElementById('hub-streak-days');

		if (pointsDisplay) pointsDisplay.textContent = `${points} CP`;
		if (targetPercent) targetPercent.textContent = `${percent}%`;
		if (completionsCount) completionsCount.textContent = todayLog.length.toString();
		if (streakDays) {
			streakDays.textContent = streak > 0 ? `${streak} ${streak === 1 ? 'Day' : 'Days'}` : '0 Days';
		}
	}

